# Public Supabase project values (safe to expose; RLS protects data)
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Server-only: required for permanent account deletion. Never prefix with PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# Canonical production URL used for auth redirects and SEO
PUBLIC_SITE_URL=https://your-scout-domain.com

# Development only. Never enable this on production.
SCOUT_DEMO_MODE=false

# Optional analytics
PUBLIC_PLAUSIBLE_DOMAIN=
