---
interface Props { variant?: "queue" | "tracker" | "documents" | "human" | "mobile"; class?: string; }
const { variant = "queue", class: cls = "" } = Astro.props;
---
<div class={`product-visual ${cls}`} data-variant={variant}>
  <div class="flex items-center justify-between border-b border-ink/10 px-4 py-3">
    <div class="flex items-center gap-2"><span class="grid h-7 w-7 place-items-center rounded-lg bg-brand-500 text-xs font-black text-brand-950">S</span><strong class="text-sm">Scout desk</strong></div>
    <span class="rounded-full bg-signal-50 px-2.5 py-1 text-[0.7rem] font-extrabold text-signal-700">Live</span>
  </div>
  <div class="grid min-h-[320px] sm:grid-cols-[132px_1fr]">
    <aside class="hidden border-r border-ink/10 bg-surface p-3 sm:block">
      {['Overview','Job queue','Applications','Documents'].map((item, i) => <p class={`mb-1 rounded-lg px-3 py-2 text-xs font-bold ${i === (variant === 'documents' ? 3 : variant === 'tracker' ? 2 : 1) ? 'bg-brand-200 text-ink' : 'text-ink-muted'}`}>{item}</p>)}
    </aside>
    <div class="bg-[#fbfff8] p-4 sm:p-5">
      {variant === "tracker" ? <div><div class="grid grid-cols-3 gap-2"><div class="rounded-lg bg-brand-100 p-3"><p class="text-xs text-ink-muted">Applications</p><strong class="mt-2 block text-2xl">42</strong></div><div class="rounded-lg bg-human-50 p-3"><p class="text-xs text-ink-muted">In review</p><strong class="mt-2 block text-2xl">3</strong></div><div class="rounded-lg bg-signal-50 p-3"><p class="text-xs text-ink-muted">Interviews</p><strong class="mt-2 block text-2xl">4</strong></div></div><div class="mt-4 space-y-2">{['Product Operations Manager','Backend Engineer','Customer Success Lead','Growth Analyst'].map((job,i)=><div class="flex items-center justify-between rounded-lg bg-white p-3 shadow-card"><div><strong class="text-sm">{job}</strong><p class="text-xs text-ink-muted">{['Northstar Health','Arcade Labs','Pilot Fiber','Apricot'][i]}</p></div><span class={`rounded-full px-2 py-1 text-[0.65rem] font-bold ${i===1?'bg-human-50 text-human-700':'bg-signal-50 text-signal-700'}`}>{i===1?'Human review':'Applied'}</span></div>)}</div></div>
      : variant === "documents" ? <div><div class="flex items-center justify-between"><div><strong>Tailored packet</strong><p class="text-xs text-ink-muted">Product Operations Manager</p></div><span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-bold">Ready</span></div><div class="mt-4 grid gap-3 sm:grid-cols-2"><div class="min-h-52 rounded-lg bg-white p-4 shadow-card"><div class="h-3 w-28 rounded bg-ink/15"></div><div class="mt-4 space-y-2">{Array.from({length:7}).map((_,i)=><div class={`h-2 rounded bg-ink/10 ${i%3===0?'w-full':'w-4/5'}`}></div>)}</div><div class="mt-5 flex flex-wrap gap-1">{['SaaS','Onboarding','Operations'].map(t=><span class="rounded bg-brand-100 px-2 py-1 text-[0.6rem] font-bold">{t}</span>)}</div></div><div class="min-h-52 rounded-lg bg-white p-4 shadow-card"><strong class="text-xs">Cover note</strong><div class="mt-4 space-y-2">{Array.from({length:9}).map((_,i)=><div class={`h-2 rounded bg-ink/10 ${i%4===0?'w-2/3':'w-full'}`}></div>)}</div></div></div></div>
      : variant === "human" ? <div><div class="rounded-lg bg-human-50 p-4"><div class="flex items-center justify-between gap-3"><div class="flex gap-3"><span class="grid h-10 w-10 place-items-center rounded-full bg-human-500 font-bold text-white">T</span><div><strong>Taylor · Human Assistant</strong><p class="mt-1 text-xs text-ink-soft">Available in your WhatsApp group</p></div></div><span class="rounded-full bg-signal-50 px-2 py-1 text-[0.65rem] font-bold text-signal-700">Applying</span></div><div class="mt-4 rounded-lg bg-white p-3 text-sm text-ink-soft">“Northstar is submitted. I used your Product profile and saved screenshots of the salary and leadership answers.”</div></div><div class="mt-4 grid grid-cols-2 gap-3"><button class="rounded-full bg-brand-950 px-4 py-3 text-sm font-bold text-white">Open evidence</button><button class="rounded-full bg-white px-4 py-3 text-sm font-bold shadow-card">Open WhatsApp</button></div></div>
      : <div><div class="flex items-end justify-between"><div><strong>Today&apos;s job queue</strong><p class="text-xs text-ink-muted">Matched to your target profile</p></div><span class="text-xs font-bold text-signal-700">9 of 12 ready</span></div><div class="mt-4 space-y-3">{['Product Operations Manager','Backend Engineer','Customer Success Lead'].map((job,i)=><article class="rounded-lg bg-white p-4 shadow-card"><div class="flex justify-between gap-3"><div><strong class="text-sm">{job}</strong><p class="text-xs text-ink-muted">{['Northstar Health','Arcade Labs','Pilot Fiber'][i]} · {['Remote','Austin','New York'][i]}</p></div><span class={`h-fit rounded-full px-2 py-1 text-[0.65rem] font-bold ${i===1?'bg-human-50 text-human-700':'bg-brand-100 text-brand-800'}`}>{i===1?'Human':'AI'}</span></div><div class="mt-3 h-1.5 rounded-full bg-surface-sunken"><div class={`h-full rounded-full bg-brand-500 ${i===0?'w-[92%]':i===1?'w-[78%]':'w-[86%]'}`}></div></div></article>)}</div></div>}
    </div>
  </div>
</div>

<style>
  .product-visual { overflow:hidden; border-radius:16px; background:white; box-shadow:0 6px 12px -8px rgba(16,33,13,.36); }
</style>
