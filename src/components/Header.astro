---
import { NAV } from "../config/site";
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import Button from "./Button.astro";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="sticky top-0 z-50 bg-surface/85 pb-3 pt-[max(.75rem,env(safe-area-inset-top))] backdrop-blur-md">
  <Container>
    <div class="flex h-14 items-center justify-between gap-4 rounded-full border border-ink/10 bg-white/80 px-3 shadow-card">
      <Logo />
      <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
        {NAV.map((item) => (
          <a
            href={item.href}
            class={`rounded-full px-3 py-2 text-sm font-semibold transition-colors duration-150 hover:bg-surface hover:text-ink ${isActive(item.href) ? "bg-surface text-ink" : "text-ink-soft"}`}
          >{item.label}</a>
        ))}
      </nav>
      <div class="hidden items-center gap-2 md:flex">
        <a href="/login" class="px-2 py-2 text-sm font-bold text-ink-soft hover:text-ink">Sign in</a>
        <Button href="/book-call" size="md" class="rounded-full bg-ink px-5 text-white hover:bg-brand-950">Book a call</Button>
      </div>

      <!-- Mobile menu: JS-free disclosure -->
      <details class="group relative md:hidden">
        <summary class="grid h-11 w-11 cursor-pointer list-none place-items-center rounded-lg border border-black/10 [&::-webkit-details-marker]:hidden">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          <span class="sr-only">Menu</span>
        </summary>
        <div class="fixed inset-x-5 top-[calc(5rem+env(safe-area-inset-top))] max-h-[calc(100dvh-6rem-env(safe-area-inset-top))] overflow-y-auto rounded-2xl border border-black/10 bg-white p-2 shadow-lift">
          {NAV.map((item) => (
            <a href={item.href} class="flex min-h-11 items-center rounded-lg px-3 py-2 text-sm text-ink-soft hover:bg-surface-sunken hover:text-ink">{item.label}</a>
          ))}
          <a href="/login" class="mt-1 block rounded-lg px-3 py-2 text-center text-sm font-bold text-ink-soft">Sign in</a><a href="/book-call" class="mt-1 block rounded-full bg-ink px-3 py-2 text-center text-sm font-medium text-white">Book a call</a>
        </div>
      </details>
    </div>
  </Container>
</header>
