---
interface Props { class?: string; href?: string | null; }
const { class: cls = "", href = "/" } = Astro.props;
const Tag = href ? "a" : "span";
---
<Tag href={href ?? undefined} class={`inline-flex items-center gap-2 font-display font-bold text-ink ${cls}`} aria-label="Scout home">
  <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
    <path fill="#9DDE47" d="M4.5 9.2c0-1.2 1.2-2 2.3-1.6l6.7 2.7v12.8l-6.7 2.7a1.7 1.7 0 0 1-2.3-1.6v-15Z" />
    <path fill="#10210D" d="m15.9 8.8 9.2-3.7c1.1-.5 2.4.4 2.4 1.6v18.6c0 1.2-1.3 2.1-2.4 1.6l-8.6-3.4V13.3l-1.2-.5c-1.8-.7-1.7-3.2.1-3.8l.5-.2Z" />
  </svg>
  <span class="text-[1.15rem] tracking-[-0.025em]">scout</span>
</Tag>
