---
import { STORE } from "../config/site";
interface Props { class?: string; label?: string; }
const { class: cls = "", label = "Scan to download" } = Astro.props;
// Placeholder QR. TODO(launch): replace with a brand-styled QR generated at build
// (e.g. `qrcode` npm) once the final domain + smart link are live, to drop the
// external dependency on api.qrserver.com.
const qr = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=0&color=0d1b2a&data=${encodeURIComponent(STORE.smartLink)}`;
---
<div class={`inline-flex flex-col items-center gap-2 rounded-2xl border border-black/5 bg-white p-4 shadow-card ${cls}`}>
  <img src={qr} width="120" height="120" alt="QR code to download Scout" loading="lazy" class="rounded-lg" />
  <span class="text-xs font-medium text-ink-soft">{label}</span>
</div>
