---
import { STORE } from "../config/site";
interface Props { class?: string; size?: "md" | "lg"; }
const { class: cls = "", size = "md" } = Astro.props;
const h = size === "lg" ? "h-14" : "h-12";
const badge = `${h} inline-flex items-center gap-3 rounded-xl bg-ink px-4 text-white transition-transform duration-200 ease-out hover:-translate-y-0.5`;
---
<div class={`flex flex-wrap items-center gap-3 ${cls}`}>
  <a href={STORE.appStore} class={badge} aria-label="Download Scout on the App Store">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M16.36 12.78c-.02-2.05 1.68-3.03 1.75-3.08-0.95-1.39-2.43-1.58-2.96-1.6-1.26-.13-2.46.74-3.1.74-.64 0-1.62-.72-2.66-.7-1.37.02-2.63.8-3.33 2.02-1.42 2.47-.36 6.12 1.02 8.12.67.98 1.48 2.08 2.53 2.04 1.02-.04 1.4-.66 2.64-.66 1.23 0 1.58.66 2.66.64 1.1-.02 1.79-1 2.46-1.98.77-1.13 1.09-2.22 1.11-2.28-.02-.01-2.13-.82-2.15-3.24ZM14.3 6.84c.56-.68.94-1.62.84-2.56-.81.03-1.79.54-2.37 1.22-.52.6-.98 1.56-.86 2.48.9.07 1.83-.46 2.39-1.14Z"/>
    </svg>
    <span class="text-left leading-none">
      <span class="block text-[0.62rem] opacity-80">Download on the</span>
      <span class="block text-[0.95rem] font-semibold">App Store</span>
    </span>
  </a>
  <a href={STORE.playStore} class={badge} aria-label="Get Scout on Google Play">
    <svg width="20" height="22" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3.6 2.3c-.2.2-.32.52-.32.93v17.54c0 .41.12.73.33.93l.06.05L13.5 12 3.66 2.25l-.06.05Z" fill="#34d399"/>
      <path d="m17.2 15.7-3.7-3.7 3.7-3.7 4.36 2.48c1.25.7 1.25 1.97 0 2.68L17.2 15.7Z" fill="#fbbf24"/>
      <path d="M13.5 12 3.6 2.25c.3-.28.77-.32 1.3-.02L17.2 8.3 13.5 12Z" fill="#60a5fa"/>
      <path d="M13.5 12 17.2 15.7 4.9 21.77c-.53.3-1 .26-1.3-.02L13.5 12Z" fill="#f87171"/>
    </svg>
    <span class="text-left leading-none">
      <span class="block text-[0.62rem] opacity-80">Get it on</span>
      <span class="block text-[0.95rem] font-semibold">Google Play</span>
    </span>
  </a>
</div>
