---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  class?: string;
  [key: string]: unknown;
}
const { href, variant = "primary", size = "md", class: cls = "", ...rest } = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 font-medium rounded-xl transition-[transform,background-color,box-shadow,color] duration-200 ease-out active:scale-[0.985] focus-visible:outline-none disabled:opacity-50";
const variants = {
  primary: "bg-brand-600 text-white hover:bg-brand-700 shadow-card hover:shadow-lift",
  secondary: "bg-white text-ink border border-black/10 hover:border-black/20 hover:bg-surface-soft",
  ghost: "text-ink-soft hover:text-ink hover:bg-surface-sunken",
};
const sizes = { md: "h-11 px-5 text-sm", lg: "h-14 px-7 text-base" };
const cn = `${base} ${variants[variant]} ${sizes[size]} ${cls}`;
const Tag = href ? "a" : "button";
---
<Tag href={href} class={cn} {...rest}><slot /></Tag>
