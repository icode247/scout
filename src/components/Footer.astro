---
import { FOOTER, SITE } from "../config/site";
import Container from "./Container.astro";
import Logo from "./Logo.astro";
// Mobile store badges intentionally disabled until the iOS and Android releases are ready.
// import AppStoreBadges from "./AppStoreBadges.astro";
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-black/5 bg-surface-soft">
  <Container class="py-14">
    <div class="grid gap-10 lg:grid-cols-[1.3fr_2fr]">
      <div>
        <Logo href="/" />
        <p class="mt-4 max-w-xs text-sm text-ink-soft">
          A done-for-you job application service with a dedicated Human Assistant or a lower-cost AI Assistant.
        </p>
        <!-- <AppStoreBadges class="mt-6" /> -->
      </div>
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {FOOTER.map((col) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wide text-ink-muted">{col.heading}</h3>
            <ul class="mt-3 space-y-2">
              {col.links.map((l) => (
                <li><a href={l.href} class="text-sm text-ink-soft transition-colors hover:text-ink">{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-black/5 pt-6 text-xs text-ink-muted sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. Powered by the FastApply automation engine.</p>
      <p>Made for job seekers who'd rather be living their life.</p>
    </div>
  </Container>
</footer>
