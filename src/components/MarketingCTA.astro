---
import Button from "./Button.astro";
interface Props { title?: string; body?: string; }
const { title = "Your next application does not need to be another night lost to forms.", body = "Book a call for a dedicated Human Assistant, or create an account and start immediately with the lower-cost AI Assistant." } = Astro.props;
---
<section class="mx-auto mb-10 max-w-container px-5 sm:px-6 lg:px-8">
  <div class="overflow-hidden rounded-2xl bg-brand-950 px-6 py-16 text-center text-white sm:px-12 sm:py-20">
    <div class="mx-auto mb-5 flex w-fit flex-wrap justify-center gap-2"><span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-bold text-brand-100">AI for routine work</span><span class="rounded-full bg-human-500/20 px-3 py-1.5 text-xs font-bold text-human-100">Human for nuance</span></div>
    <h2 class="mx-auto max-w-4xl font-display text-4xl font-extrabold leading-tight text-white sm:text-6xl">{title}</h2>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70">{body}</p>
    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row"><Button href="/book-call" size="lg" class="rounded-full bg-brand-300 px-8 font-bold text-ink hover:bg-brand-200">Book a free strategy call</Button><Button href="/login?intent=ai" size="lg" variant="ghost" class="rounded-full bg-white/10 text-white hover:bg-white/15">Start with AI</Button></div><p class="mt-4 text-xs font-semibold text-white/45">Human starts with a conversation · AI starts with guided resume import</p>
  </div>
</section>
