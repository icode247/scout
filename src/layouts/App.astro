---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Logo from "../components/Logo.astro";
interface Props { title: string; active?: string; }
const { title, active = "dashboard" } = Astro.props;
const profile = Astro.locals.scoutProfile;
const user = Astro.locals.user;
const name = profile?.full_name || user?.user_metadata?.full_name || user?.email?.split("@")[0] || "Scout member";
const initials = name.split(/\s+/).map((part:string)=>part[0]).join("").slice(0,2).toUpperCase();
const assistantType = profile?.assistant_type || "ai";
const assistantName = profile?.assistant_name || (assistantType === "human" ? "Your assistant" : "Scout AI");
const nav = [
  { id: "dashboard", label: "Overview", href: "/dashboard", icon: "⌂" },
  { id: "jobs", label: "Jobs", href: "/jobs", icon: "⌕" },
  { id: "applications", label: "Applications", href: "/applications", icon: "✓" },
  { id: "profiles", label: "Job profiles", href: "/profiles", icon: "◎" },
  { id: "resumes", label: "Resumes", href: "/profiles#resumes", icon: "▤" },
];
---
<!doctype html>
<html lang="en">
<head><BaseHead title={title} noindex={true} /><script is:inline>document.documentElement.classList.add("js");</script></head>
<body class="min-h-screen bg-[#f7faf5] font-sans text-ink">
  <div class="min-h-screen lg:grid lg:grid-cols-[240px_1fr]">
    <aside class="hidden border-r border-ink/10 bg-white lg:fixed lg:inset-y-0 lg:flex lg:w-[240px] lg:flex-col">
      <div class="p-5"><Logo /></div>
      <nav class="mt-5 space-y-1 px-3" aria-label="Product">
        {nav.map(item => <a href={item.href} aria-current={active===item.id?"page":undefined} class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-bold ${active===item.id?"bg-brand-100 text-ink":"text-ink-soft hover:bg-surface"}`}><span class="grid h-7 w-7 place-items-center rounded-md bg-white">{item.icon}</span>{item.label}</a>)}
      </nav>
      <div class="mx-3 mt-8 rounded-xl bg-brand-950 p-4 text-white"><p class="text-xs font-bold text-brand-300">{assistantType.toUpperCase()} ASSISTANT</p><strong class="mt-2 block text-sm text-white">{assistantName} is ready</strong><p class="mt-1 text-xs text-white/60">{assistantType === "human" ? "Chat and application evidence included" : "Your automated queue is active"}</p>{assistantType==="human" && <a href={profile?.whatsapp_url || "https://wa.me/"} class="mt-4 block rounded-full bg-white px-3 py-2 text-center text-xs font-extrabold text-ink">Open WhatsApp</a>}</div>
      <div class="mt-auto border-t border-ink/10 p-3"><a href="/download" class="block rounded-lg px-3 py-2 text-sm font-bold text-ink-soft hover:bg-surface">Add Scout to Chrome</a><a href="/support" class="block rounded-lg px-3 py-2 text-sm font-bold text-ink-soft hover:bg-surface">Get support</a><div class="mt-3 flex items-center gap-3 rounded-lg bg-surface p-3"><span class="grid h-9 w-9 place-items-center rounded-full bg-brand-300 font-bold">{initials}</span><div class="min-w-0 flex-1"><strong class="block truncate text-sm">{name}</strong><span class="text-xs text-ink-muted">{assistantType === "human" ? "Human" : "AI"} plan</span></div><form action="/api/auth/logout" method="post"><button class="text-xs font-bold text-ink-muted hover:text-ink" title="Sign out" aria-label="Sign out">↗</button></form></div></div>
    </aside>
    <div class="lg:col-start-2">
      <header class="sticky top-0 z-40 border-b border-ink/10 bg-white/95 px-4 py-3 backdrop-blur lg:hidden"><div class="flex items-center justify-between"><Logo /><details class="relative"><summary class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-lg bg-surface [&::-webkit-details-marker]:hidden">☰</summary><nav class="absolute right-0 mt-2 w-56 rounded-xl bg-white p-2 shadow-lift">{nav.map(item=><a href={item.href} class="block rounded-lg px-3 py-2 text-sm font-bold hover:bg-surface">{item.label}</a>)}<form action="/api/auth/logout" method="post"><button class="block w-full rounded-lg px-3 py-2 text-left text-sm font-bold hover:bg-surface">Sign out</button></form></nav></details></div></header>
      <main class="mx-auto max-w-[1440px] p-4 sm:p-6 lg:p-8"><slot /></main>
    </div>
  </div>
  <div id="toast" class="pointer-events-none fixed bottom-5 left-1/2 z-[100] hidden -translate-x-1/2 rounded-full bg-ink px-5 py-3 text-sm font-bold text-white shadow-lift" role="status" aria-live="polite"></div>
  <script is:inline>
    window.scoutToast = function(message, error) {
      const toast = document.getElementById("toast");
      if (!toast) return;
      toast.textContent = message;
      toast.classList.remove("hidden", "bg-ink", "bg-red-700");
      toast.classList.add(error ? "bg-red-700" : "bg-ink");
      clearTimeout(window.__scoutToastTimer);
      window.__scoutToastTimer = setTimeout(() => toast.classList.add("hidden"), 3200);
    };
  </script>
</body>
</html>
