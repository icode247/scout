---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Logo from "../components/Logo.astro";
import { adminEmails } from "../lib/admin";
import { assignedHumanAssistant } from "../lib/human-assistants";
interface Props { title: string; active?: string; }
const { title, active = "dashboard" } = Astro.props;
const profile = Astro.locals.scoutProfile;
const user = Astro.locals.user;
const name = profile?.full_name || user?.user_metadata?.full_name || user?.email?.split("@")[0] || "Scout member";
const initials = name.split(/\s+/).map((part:string)=>part[0]).join("").slice(0,2).toUpperCase();
const assistantType = profile?.assistant_type || "ai";
const humanAssistant = assignedHumanAssistant(user?.id || profile?.user_id || "scout-member", profile?.assistant_name);
const assistantName = assistantType === "human" ? humanAssistant.name : "Scout AI";
const chromeExtensionUrl = import.meta.env.PUBLIC_CHROME_EXTENSION_URL?.trim();
const nav = [
  { id: "dashboard", label: "Overview", href: "/dashboard", icon: "⌂" },
  ...(assistantType === "ai" ? [{ id: "agent", label: "Scout AI", href: "/agent", icon: "✦" }] : []),
  { id: "jobs", label: "Jobs", href: "/jobs", icon: "⌕" },
  { id: "applications", label: "Applications", href: "/applications", icon: "✓" },
  { id: "profiles", label: "Job profiles", href: "/profiles", icon: "◎" },
  { id: "resumes", label: "Resumes", href: "/profiles#resumes", icon: "▤" },
  { id: "settings", label: "Settings", href: "/settings", icon: "⚙" },
];
if (user?.email && adminEmails().has(user.email.toLowerCase())) nav.push({ id: "admin", label: "Operations", href: "/admin", icon: "↗" });
---
<!doctype html>
<html lang="en">
<head><BaseHead title={title} noindex={true} analytics={false} /><script is:inline>document.documentElement.classList.add("js");</script></head>
<body class="min-h-screen bg-[#f7faf5] font-sans text-ink">
  <div class="min-h-screen lg:grid lg:grid-cols-[240px_1fr]">
    <aside class="hidden border-r border-ink/10 bg-white lg:fixed lg:inset-y-0 lg:flex lg:w-[240px] lg:flex-col">
      <div class="p-5"><Logo /></div>
      <nav class="mt-5 space-y-1 px-3" aria-label="Product">
        {nav.map(item => <a href={item.href} aria-current={active===item.id?"page":undefined} class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-bold ${active===item.id?"bg-brand-100 text-ink":"text-ink-soft hover:bg-surface"}`}><span class="grid h-7 w-7 place-items-center rounded-md bg-white">{item.icon}</span>{item.label}</a>)}
      </nav>
      <div class="mx-3 mt-8 rounded-xl bg-brand-950 p-4 text-white"><p class="text-xs font-bold text-brand-300">{assistantType.toUpperCase()} ASSISTANT</p>{assistantType === "human" ? <div class="mt-3 flex items-center gap-3"><img src={humanAssistant.avatar} alt="" class="h-10 w-10 rounded-full object-cover ring-2 ring-white/20" /><div class="min-w-0"><strong class="block truncate text-sm text-white">{assistantName}</strong><span class="text-xs text-white/55">Assigned to your desk</span></div></div> : <strong class="mt-2 block text-sm text-white">Scout AI is ready</strong>}<p class="mt-1 text-xs text-white/60">{assistantType === "human" ? (profile?.whatsapp_url ? "WhatsApp and application evidence are ready" : "WhatsApp group setup is in progress") : "Your automated queue is active"}</p>{assistantType==="human" && profile?.whatsapp_url && <a href={profile.whatsapp_url} rel="noopener noreferrer" class="mt-4 block rounded-full bg-white px-3 py-2 text-center text-xs font-extrabold text-ink">Open WhatsApp group</a>}</div>
      <div class="mt-auto border-t border-ink/10 p-3">{assistantType === "human" && (chromeExtensionUrl ? <a href={chromeExtensionUrl} rel="noopener noreferrer" class="block rounded-lg px-3 py-2 text-sm font-bold text-ink-soft hover:bg-surface">Add Scout to Chrome</a> : <span class="block rounded-lg px-3 py-2 text-sm font-bold text-ink-muted">Chrome extension coming soon</span>)}<a href="/support" class="block rounded-lg px-3 py-2 text-sm font-bold text-ink-soft hover:bg-surface">Get support</a><div class="mt-3 flex items-center gap-3 rounded-lg bg-surface p-3"><span class="grid h-9 w-9 place-items-center rounded-full bg-brand-300 font-bold">{initials}</span><div class="min-w-0 flex-1"><strong class="block truncate text-sm">{name}</strong><span class="text-xs text-ink-muted">{assistantType === "human" ? "Human" : "AI"} plan</span></div><form action="/api/auth/logout" method="post"><button class="text-xs font-bold text-ink-muted hover:text-ink" title="Sign out" aria-label="Sign out">↗</button></form></div></div>
    </aside>
    <div class="lg:col-start-2">
      <header class="sticky top-0 z-40 border-b border-ink/10 bg-white/95 px-4 py-3 pt-[max(.75rem,env(safe-area-inset-top))] backdrop-blur lg:hidden"><div class="flex items-center justify-between"><Logo /><details class="relative"><summary class="grid h-11 w-11 cursor-pointer list-none place-items-center rounded-lg bg-surface text-lg [&::-webkit-details-marker]:hidden">☰</summary><nav class="fixed inset-x-3 top-[calc(4.5rem+env(safe-area-inset-top))] max-h-[calc(100dvh-5.5rem-env(safe-area-inset-top))] overflow-y-auto rounded-xl bg-white p-2 shadow-lift">{nav.map(item=><a href={item.href} class:list={["flex min-h-11 items-center rounded-lg px-3 py-2 text-sm font-bold hover:bg-surface",active===item.id&&"bg-brand-100"]}>{item.label}</a>)}<form action="/api/auth/logout" method="post"><button class="flex min-h-11 w-full items-center rounded-lg px-3 py-2 text-left text-sm font-bold hover:bg-surface">Sign out</button></form></nav></details></div></header>
      <main class="mx-auto min-w-0 max-w-[1440px] p-4 pb-[max(1rem,env(safe-area-inset-bottom))] sm:p-6 lg:p-8"><slot /></main>
    </div>
  </div>
  <div id="toast" class="pointer-events-none fixed bottom-[max(1.25rem,env(safe-area-inset-bottom))] left-4 right-4 z-[100] hidden rounded-xl bg-ink px-5 py-3 text-center text-sm font-bold text-white shadow-lift sm:left-1/2 sm:right-auto sm:-translate-x-1/2 sm:rounded-full" role="status" aria-live="polite"></div>
  <script is:inline>
    window.scoutToast = function(message, error) {
      const toast = document.getElementById("toast");
      if (!toast) return;
      toast.textContent = message;
      toast.classList.remove("hidden", "bg-ink", "bg-red-700");
      toast.classList.add(error ? "bg-red-700" : "bg-ink");
      clearTimeout(window.__scoutToastTimer);
      window.__scoutToastTimer = setTimeout(() => toast.classList.add("hidden"), 3200);
    };
  </script>
</body>
</html>
