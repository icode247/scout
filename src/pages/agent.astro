---
import App from "../layouts/App.astro";
import { loadScoutData } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
if (Astro.locals.scoutProfile?.assistant_type !== "ai") return Astro.redirect("/dashboard");
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const profiles = data.jobProfiles.filter((profile) => profile.active);
---
<App title="Scout AI" active="agent">
<div class="mx-auto max-w-6xl">
<header class="flex flex-wrap items-end justify-between gap-5"><div><p class="text-sm font-bold text-signal-700">Scout AI Agent</p><h1 class="mt-1 text-3xl font-extrabold">Tell Scout what a good job looks like.</h1><p class="mt-2 max-w-2xl text-ink-soft">Scout searches and applies through the application service. You do not need the Chrome extension or to add jobs manually.</p></div><a href="/jobs" class="rounded-full bg-white px-5 py-3 text-sm font-extrabold shadow-card">Review matching jobs</a></header>
{profiles.length ? <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_19rem]"><section class="overflow-hidden rounded-2xl bg-white shadow-card">
<div class="border-b border-ink/10 bg-brand-950 p-5 text-white"><div class="flex items-center gap-3"><span class="grid h-11 w-11 place-items-center rounded-full bg-brand-300 font-extrabold text-brand-950">S</span><div><strong class="text-white">Scout AI</strong><p class="text-xs text-white/60">Application agent</p></div></div></div>
<form id="agent-form" data-profiles={JSON.stringify(profiles)} class="space-y-6 p-5 sm:p-7">
<div class="flex gap-3"><span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-100 text-xs font-extrabold">AI</span><div class="max-w-xl rounded-2xl rounded-tl-sm bg-surface p-4 text-sm leading-relaxed">Which job profile should I work on? Each profile can have its own roles, locations, and application rules.</div></div>
<label class="ml-11 block text-sm font-bold">Job profile<select name="jobProfileId" id="profile-select" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3">{profiles.map(p=><option value={p.id}>{p.name}</option>)}</select></label>
<div class="flex gap-3"><span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-100 text-xs font-extrabold">AI</span><div class="max-w-xl rounded-2xl rounded-tl-sm bg-surface p-4 text-sm">What roles and locations should I search?</div></div>
<div class="ml-11 grid gap-4 sm:grid-cols-2"><label class="text-sm font-bold">Target roles<input required name="roles" placeholder="Java Developer, Backend Developer" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold">Locations<input required name="locations" placeholder="United States, Canada, Remote" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold sm:col-span-2">Companies to avoid <span class="font-normal text-ink-muted">(optional)</span><input name="companyBlacklist" placeholder="Acme Corp, Globex" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label></div>
<div class="flex gap-3"><span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-100 text-xs font-extrabold">AI</span><div class="max-w-xl rounded-2xl rounded-tl-sm bg-surface p-4 text-sm">Now set the guardrails. I will only apply when a job clears them.</div></div>
<div class="ml-11 grid gap-4 sm:grid-cols-3"><label class="text-sm font-bold">Employment<select name="employmentTypes" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-3 py-3 font-normal"><option value="full-time">Full-time</option><option value="part-time">Part-time</option><option value="contractor">Contract</option><option value="">Any</option></select></label><label class="text-sm font-bold">Experience<select name="experienceLevels" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-3 py-3 font-normal"><option value="entry">Entry</option><option value="mid">Mid</option><option value="senior">Senior</option><option value="executive">Executive</option><option value="">Any</option></select></label><label class="text-sm font-bold">Work mode<select name="workModes" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-3 py-3 font-normal"><option value="remote">Remote</option><option value="hybrid">Hybrid</option><option value="onsite">On-site</option><option value="">Any</option></select></label></div>
<div class="ml-11 rounded-xl border border-ink/10 p-4"><label class="flex items-center justify-between gap-4 text-sm font-bold"><span>Minimum match score <output id="score-output">70%</output></span><input name="accuracyThreshold" type="range" min="50" max="100" value="70" class="w-40 accent-brand-700"/></label><div class="mt-4 grid gap-3 sm:grid-cols-2"><label class="flex items-start gap-3 text-sm"><input name="resumePerJob" type="checkbox" class="mt-1 h-4 w-4 accent-brand-700"/><span><strong class="block">Tailor resume per job</strong><span class="text-ink-muted">Generate a targeted resume before applying.</span></span></label><label class="flex items-start gap-3 text-sm"><input name="stealthApply" type="checkbox" class="mt-1 h-4 w-4 accent-brand-700"/><span><strong class="block">Human-paced applications</strong><span class="text-ink-muted">Apply more slowly with natural timing.</span></span></label></div></div>
<div id="agent-message" role="status" aria-live="polite" class="hidden rounded-xl p-4 text-sm font-bold"></div>
<div class="ml-11 flex flex-wrap gap-3"><button type="submit" data-action="activate" class="rounded-full bg-ink px-6 py-3 text-sm font-extrabold text-white">Activate Scout AI</button><button type="submit" data-action="save" class="rounded-full bg-surface px-6 py-3 text-sm font-extrabold">Save draft</button><button type="submit" data-action="pause" id="pause-button" class="hidden rounded-full px-5 py-3 text-sm font-bold text-red-700">Pause automation</button></div>
</form></section>
<aside class="h-fit rounded-2xl bg-brand-100 p-5"><p class="text-xs font-bold text-brand-800">HOW THIS WORKS</p><ol class="mt-4 space-y-4 text-sm"><li><strong class="block">1. You set the brief</strong><span class="text-ink-soft">One configuration per job profile.</span></li><li><strong class="block">2. Scout finds matches</strong><span class="text-ink-soft">Jobs appear on your Jobs page.</span></li><li><strong class="block">3. Scout applies</strong><span class="text-ink-soft">Automatic and one-click applications use the FastApply API.</span></li><li><strong class="block">4. You stay in control</strong><span class="text-ink-soft">Return here to adjust or pause the agent.</span></li></ol></aside></div>
: <div class="mt-8 rounded-2xl bg-white p-10 text-center shadow-card"><h2 class="text-2xl font-extrabold">Create a job profile first</h2><p class="mt-2 text-ink-soft">Scout needs your profile and resume before it can search or apply.</p><a href="/profiles" class="mt-6 inline-block rounded-full bg-ink px-6 py-3 text-sm font-extrabold text-white">Create job profile</a></div>}
</div></App>
<script>
// @ts-nocheck
const form=document.querySelector("#agent-form"),select=document.querySelector("#profile-select"),message=document.querySelector("#agent-message"),pause=document.querySelector("#pause-button");let configs=[];const profiles=form?JSON.parse(form.dataset.profiles||"[]"):[];
const split=v=>String(v||"").split(",").map(x=>x.trim()).filter(Boolean);
function show(text,error=false){message.textContent=text;message.className="rounded-xl p-4 text-sm font-bold "+(error?"bg-red-50 text-red-800":"bg-signal-50 text-signal-800")}
function fill(){const c=configs.find(x=>x.job_profile_id===select.value),p=profiles.find(x=>x.id===select.value);form.elements.roles.value=(c?.roles||p?.target_roles||[]).join(", ");form.elements.locations.value=(c?.locations||p?.locations||[]).join(", ");form.elements.companyBlacklist.value=(c?.company_blacklist||[]).join(", ");form.elements.employmentTypes.value=c?.employment_types?.[0]||"full-time";form.elements.experienceLevels.value=c?.experience_levels?.[0]||"entry";form.elements.workModes.value=c?.work_modes?.[0]||"remote";form.elements.accuracyThreshold.value=c?.accuracy_threshold||70;form.elements.resumePerJob.checked=Boolean(c?.resume_per_job);form.elements.stealthApply.checked=Boolean(c?.stealth_apply);document.querySelector("#score-output").textContent=form.elements.accuracyThreshold.value+"%";pause.classList.toggle("hidden",!c?.first_apply_id||c?.status==="paused")}
if(form){fetch("/api/app/ai-agent").then(r=>r.json()).then(d=>{configs=d.configs||[];fill()}).catch(()=>show("I could not load your saved settings.",true));select.addEventListener("change",fill);form.elements.accuracyThreshold.addEventListener("input",e=>document.querySelector("#score-output").textContent=e.target.value+"%");
form.addEventListener("submit",async e=>{e.preventDefault();const button=e.submitter,action=button?.dataset.action||"save",fd=new FormData(form);button.disabled=true;show(action==="activate"?"Connecting your profile and activating Scout AI…":"Saving your settings…");try{const response=await fetch("/api/app/ai-agent",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({action,jobProfileId:fd.get("jobProfileId"),roles:split(fd.get("roles")),locations:split(fd.get("locations")),companyBlacklist:split(fd.get("companyBlacklist")),employmentTypes:split(fd.get("employmentTypes")),experienceLevels:split(fd.get("experienceLevels")),workModes:split(fd.get("workModes")),accuracyThreshold:Number(fd.get("accuracyThreshold")),resumePerJob:fd.get("resumePerJob")==="on",stealthApply:fd.get("stealthApply")==="on"})});const d=await response.json();if(!response.ok)throw new Error(d.error||"Unable to save settings");configs=configs.filter(x=>x.job_profile_id!==d.config.job_profile_id).concat(d.config);show(action==="activate"?"Scout AI is active. I will use these rules for this profile.":action==="pause"?"Automation paused.":"Settings saved.");fill()}catch(err){show(err.message||"Unable to save settings",true)}finally{button.disabled=false}})}
</script>