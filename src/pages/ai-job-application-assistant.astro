---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import ProductScreenshot from "../components/ProductScreenshot.astro";
import MarketingCTA from "../components/MarketingCTA.astro";
---
<Base title="AI Job Application Assistant That Applies for You" description="Let Scout's AI job application assistant find matching roles, tailor your resume, submit applications, and track every job for $39 per month.">
  <section class="bg-brand-100 py-20 sm:py-28"><Container><div class="grid items-center gap-12 lg:grid-cols-[0.82fr_1.18fr]"><div><span class="rounded-full bg-brand-950 px-3 py-1.5 text-sm font-bold text-white">AI Assistant · from $39/mo</span><h1 class="mt-6 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] sm:text-7xl">An AI job application assistant that applies for you.</h1><p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">For busy job seekers who do not have time to apply: Scout finds relevant openings, tailors each application, submits it, and records the work.</p><Button href="/login?intent=ai" size="lg" class="mt-8 rounded-full bg-brand-950 text-white">Create my AI Assistant account</Button><p class="mt-3 text-sm font-semibold text-ink-muted">No call required · Guided resume import</p></div><ProductScreenshot variant="queue" /></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">What the AI assistant handles.</h2><p class="mt-5 text-lg text-ink-soft">Repeatable application work, completed with a consistent process instead of copied generic answers.</p></div><div class="mt-14 grid gap-5 lg:grid-cols-3"><article class="rounded-2xl bg-brand-200 p-7"><h3 class="text-2xl font-extrabold">Find and rank</h3><p class="mt-3 leading-relaxed text-ink-soft">Match roles against your experience, preferences, salary floor, and exclusions.</p></article><article class="rounded-2xl bg-surface p-7"><h3 class="text-2xl font-extrabold">Prepare the packet</h3><p class="mt-3 leading-relaxed text-ink-soft">Tailor resume language, cover notes, and repeated ATS answers to the role.</p></article><article class="rounded-2xl bg-brand-950 p-7 text-white"><h3 class="text-2xl font-extrabold text-white">Submit and log</h3><p class="mt-3 leading-relaxed text-white/70">Apply at safe pacing and save a record of the materials and confirmation.</p></article></div></Container></section>
  <section class="bg-surface py-20 sm:py-28"><Container><div class="grid items-center gap-10 lg:grid-cols-2"><div><p class="text-lg font-bold text-brand-700">Tailored for the actual posting</p><h2 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">The same profile. A different packet for each role.</h2><p class="mt-5 text-lg leading-relaxed text-ink-soft">Scout reads the requirements, selects relevant experience, and prepares job-specific materials before anything moves.</p></div><ProductScreenshot variant="documents" /></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="grid items-center gap-10 lg:grid-cols-2"><ProductScreenshot variant="tracker" /><div><p class="text-lg font-bold text-signal-700">Visible from start to finish</p><h2 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">You never have to wonder what the agent did.</h2><p class="mt-5 text-lg leading-relaxed text-ink-soft">Your tracker shows every job, document packet, submission time, and resume used. Detailed screenshots of form answers are available on Human Assistant plans.</p><a href="/safety" class="mt-6 inline-flex font-bold text-brand-700">See Scout's safety controls →</a></div></div></Container></section>
  <MarketingCTA title="Give the routine applications to Scout AI." body="Create an account, review the data extracted from your resume, and open a prepared dashboard without booking a call." />
</Base>
