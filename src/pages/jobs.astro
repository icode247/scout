---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { loadScoutData, profileById } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const jobs = data.jobs.map(job => {
  const profile = profileById(data, job.job_profile_id);
  return {
    ...job,
    posted: new Intl.RelativeTimeFormat("en",{numeric:"auto"}).format(Math.round((new Date(job.created_at).getTime()-Date.now())/86400000),"day"),
    initials: job.company.split(/\s+/).map((part:string)=>part[0]).join("").slice(0,2).toUpperCase(),
    resume: data.resumes[0]?.name || "Resume will be assigned",
    summary: job.description || "No job description was provided. Open the original listing or paste the description when adding the job.",
    skills: profile?.target_roles.length ? profile.target_roles : ["Role fit", "Experience", "Location"],
    profileName: profile?.name || "General profile",
    assistantName: job.assistant_type === "human"
      ? (data.profile.assistant_type === "human" && data.profile.assistant_name ? data.profile.assistant_name : "Human Assistant")
      : "Scout AI",
  };
});
const first = jobs[0] || null;
---
<App title="Jobs | Scout" active="jobs">
  <header class="jobs-heading"><div><p class="text-sm font-bold text-signal-700">Jobs workspace</p><h1 class="mt-1 text-2xl font-extrabold">Find work worth applying to.</h1></div><div class="flex w-full items-center justify-end gap-3 lg:w-auto"><label class="jobs-search" for="job-search"><span>⌕</span><input id="job-search" type="search" placeholder="Search title, company, or skill" autocomplete="off"/></label><AddJobDialog profiles={data.jobProfiles}/></div></header>
  <div class="jobs-controls"><div class="jobs-tabs" role="tablist"><button class="job-tab is-active" data-status="all">All <span>{jobs.length}</span></button><button class="job-tab" data-status="saved">Saved <span>{jobs.filter(j=>j.status==="saved").length}</span></button><button class="job-tab" data-status="delegated">Delegated <span>{jobs.filter(j=>j.status==="delegated"||j.status==="preparing").length}</span></button><button class="job-tab" data-status="applied">Applied <span>{jobs.filter(j=>j.status==="applied").length}</span></button></div><label class="text-xs font-bold text-ink-muted">Jobs for <select id="profile-filter" class="jobs-select"><option value="all">All profiles</option>{data.jobProfiles.map(profile=><option value={profile.id}>{profile.name}</option>)}</select></label></div>
  {first ? <div class="jobs-workspace">
    <aside class="jobs-results"><div class="results-heading"><div><strong id="result-count">{jobs.length} jobs</strong><p>From your assistant queue</p></div><span>☷</span></div><div id="job-results" class="divide-y divide-ink/10">{jobs.map((job,index)=><button type="button" class:list={["job-result",index===0&&"is-selected"]} data-index={index} data-id={job.id} data-status={job.status} data-profile={job.job_profile_id || ""} data-search={`${job.title} ${job.company} ${job.skills.join(" ")}`.toLowerCase()}><span class="company-mark">{job.initials}</span><span class="min-w-0 flex-1"><strong class="block truncate">{job.title}</strong><span class="mt-1 block truncate text-xs text-ink-soft">{job.company}</span><span class="mt-2 block text-xs text-ink-muted">{job.location || "Location not set"} · {job.posted}</span></span><span class="fit-score"><strong>{job.fit_score}%</strong><small>fit</small></span></button>)}</div><div id="jobs-empty" class="hidden p-8 text-center"><strong>No jobs found.</strong><p class="mt-2 text-sm text-ink-muted">Try another search or profile.</p></div></aside>
    <section class="job-detail"><header class="detail-heading"><div class="min-w-0"><p class="text-sm text-ink-muted"><strong id="detail-company" class="text-ink">{first.company}</strong> · <span id="detail-posted">{first.posted}</span></p><h2 id="detail-title" class="mt-2 text-3xl font-extrabold">{first.title}</h2><p id="detail-location" class="mt-2 text-sm text-ink-soft">{first.location}</p></div><div class="flex shrink-0 items-start gap-2"><button id="save-job" class="icon-button" aria-label="Save job">♡</button><button id="delegate-job" class="primary-action">Send to {first.assistantName} →</button></div></header>
      <div class="handoff"><div><p id="assistant-type" class="text-xs font-bold text-human-700">{first.assistant_type.toUpperCase()} ASSISTANT</p><h3 class="mt-1 text-lg font-extrabold"><span id="assistant-name">{first.assistantName}</span> can handle this application.</h3><p class="mt-1 text-sm text-ink-soft">Your profile and resume rules stay attached to the job.</p></div><div class="text-right text-xs font-bold text-ink-muted">Using profile<strong id="profile-name" class="mt-1 block text-sm text-ink">{first.profileName}</strong></div></div>
      <div class="tool-tabs"><button class="tool-tab is-active" data-tool="fit">◎ Fit analysis</button><button class="tool-tab" data-tool="resume">▤ Resume</button><button class="tool-tab" data-tool="answers">☷ Answer plan</button></div>
      <div class="detail-body"><section id="fit-panel" class="tool-panel"><div class="fit-summary"><div class="fit-ring"><strong id="detail-score">{first.fit_score}</strong><span>% fit</span></div><div><h3 class="text-lg font-extrabold">Profile match</h3><p class="mt-1 text-sm leading-relaxed text-ink-soft">Scout compares this role with your selected profile and approved preferences.</p></div></div><h3 class="mt-7 font-extrabold">Profile targets</h3><div id="detail-skills" class="mt-3 flex flex-wrap gap-2">{first.skills.map(skill=><span class="skill-tag is-match">✓ {skill}</span>)}</div></section><section id="resume-panel" class="tool-panel hidden"><h3 class="text-lg font-extrabold">Resume Scout will use</h3><p class="mt-2 text-sm text-ink-soft">Your job profile controls whether Scout tailors a copy or keeps your original.</p><div class="document-row"><span class="document-icon">PDF</span><strong id="detail-resume" class="block truncate">{first.resume}</strong></div></section><section id="answers-panel" class="tool-panel hidden"><h3 class="text-lg font-extrabold">Application answer plan</h3><p class="mt-2 text-sm text-ink-soft">Known answers come from your profile. A Human Assistant asks in WhatsApp before ambiguous answers.</p></section><section class="mt-8 border-t border-ink/10 pt-7"><h3 class="text-lg font-extrabold">About the role</h3><p id="detail-summary" class="mt-3 max-w-prose whitespace-pre-line text-sm leading-7 text-ink-soft">{first.summary}</p><a id="original-link" href={first.external_url || "#"} target="_blank" class:list={["mt-5 inline-flex text-sm font-extrabold text-brand-700",!first.external_url&&"hidden"]}>Open original listing →</a></section></div>
    </section>
  </div> : <div class="mt-8 rounded-xl bg-white p-12 text-center shadow-card"><h2 class="text-2xl font-extrabold">Your jobs workspace is ready</h2><p class="mx-auto mt-3 max-w-md text-ink-soft">Add a job you found, choose a profile, and send it to your Human or AI Assistant.</p><div class="mt-6"><AddJobDialog profiles={data.jobProfiles} id="jobs-empty-add"/></div></div>}
  <script define:vars={{ jobs }}>
    const results=[...document.querySelectorAll(".job-result")],statusTabs=[...document.querySelectorAll(".job-tab")],toolTabs=[...document.querySelectorAll(".tool-tab")],search=document.querySelector("#job-search"),profileFilter=document.querySelector("#profile-filter");let status="all",selected=jobs[0];
    function filter(){const query=search?.value.trim().toLowerCase()||"",profile=profileFilter?.value||"all";let count=0;results.forEach(button=>{const group=status==="all"||button.dataset.status===status||(status==="delegated"&&button.dataset.status==="preparing");const show=group&&(profile==="all"||button.dataset.profile===profile)&&(!query||(button.dataset.search || "").includes(query));button.classList.toggle("hidden",!show);if(show)count++});document.querySelector("#jobs-empty")?.classList.toggle("hidden",count!==0);if(document.querySelector("#result-count"))document.querySelector("#result-count").textContent=count+(count===1?" job":" jobs")}
    function render(job){selected=job;document.querySelector("#detail-company").textContent=job.company;document.querySelector("#detail-posted").textContent=job.posted;document.querySelector("#detail-title").textContent=job.title;document.querySelector("#detail-location").textContent=job.location||"Location not set";document.querySelector("#detail-score").textContent=job.fit_score;document.querySelector("#detail-summary").textContent=job.summary;document.querySelector("#detail-resume").textContent=job.resume;document.querySelector("#profile-name").textContent=job.profileName;document.querySelector("#assistant-name").textContent=job.assistantName;document.querySelector("#assistant-type").textContent=job.assistant_type.toUpperCase()+" ASSISTANT";const skills=document.querySelector("#detail-skills");skills.replaceChildren(...job.skills.map(skill=>{const tag=document.createElement("span");tag.className="skill-tag is-match";tag.textContent="✓ "+skill;return tag}));const link=document.querySelector("#original-link");link.href=job.external_url||"#";link.classList.toggle("hidden",!job.external_url);const done=["delegated","preparing","applied","interview"].includes(job.status),delegate=document.querySelector("#delegate-job");delegate.textContent=done?"In assistant queue ✓":"Send to "+job.assistantName+" →";delegate.disabled=done;document.querySelector("#save-job").setAttribute("aria-pressed",job.status==="saved"?"true":"false")}
    async function setStatus(next){const response=await fetch("/api/app/jobs",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify({id:selected.id,status:next})});const data=await response.json();if(!response.ok){window.scoutToast?.(data.error||"Could not update job",true);return false}selected.status=next;const button=results.find(item=>item.dataset.id===selected.id);if(button)button.dataset.status=next;window.scoutToast?.(next==="delegated"?"Job sent to your assistant":"Job updated");return true}
    results.forEach(button=>button.addEventListener("click",()=>{results.forEach(item=>item.classList.remove("is-selected"));button.classList.add("is-selected");render(jobs[Number(button.dataset.index)])}));
    statusTabs.forEach(tab=>tab.addEventListener("click",()=>{status=tab.dataset.status;statusTabs.forEach(item=>item.classList.toggle("is-active",item===tab));filter()}));search?.addEventListener("input",filter);profileFilter?.addEventListener("change",filter);
    toolTabs.forEach(tab=>tab.addEventListener("click",()=>{toolTabs.forEach(item=>item.classList.toggle("is-active",item===tab));document.querySelectorAll(".tool-panel").forEach(panel=>panel.classList.add("hidden"));document.querySelector("#"+tab.dataset.tool+"-panel")?.classList.remove("hidden")}));
    document.querySelector("#delegate-job")?.addEventListener("click",async event=>{event.currentTarget.disabled=true;if(await setStatus("delegated"))render(selected);else event.currentTarget.disabled=false});
    document.querySelector("#save-job")?.addEventListener("click",async event=>{const next=selected.status==="saved"?"skipped":"saved";if(await setStatus(next)){event.currentTarget.setAttribute("aria-pressed",next==="saved"?"true":"false");event.currentTarget.textContent=next==="saved"?"♥":"♡"}});
  </script>
</App>
<style>
.jobs-heading{display:flex;align-items:end;justify-content:space-between;gap:1.5rem}.jobs-search{display:flex;width:min(100%,25rem);align-items:center;gap:.65rem;border:1px solid rgb(20 33 15/.14);border-radius:999px;background:white;padding:.7rem 1rem}.jobs-search input{min-width:0;width:100%;outline:0}.jobs-controls{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:1.5rem;border-bottom:1px solid rgb(20 33 15/.1);padding-bottom:.75rem}.jobs-tabs{display:flex;gap:.25rem;overflow:auto}.job-tab{border-radius:999px;padding:.55rem .9rem;color:#69735f;font-size:.8rem;font-weight:800}.job-tab.is-active{background:#10210d;color:white}.jobs-select{margin-left:.5rem;border:1px solid rgb(20 33 15/.12);border-radius:.6rem;background:white;padding:.58rem .75rem;font-size:.75rem}.jobs-workspace{display:grid;grid-template-columns:23rem minmax(0,1fr);min-height:44rem;margin-top:1rem;overflow:hidden;border-radius:.875rem;background:white;box-shadow:0 8px 24px -12px rgb(13 27 42/.12)}.jobs-results{border-right:1px solid rgb(20 33 15/.1)}.results-heading{display:flex;justify-content:space-between;padding:1rem;border-bottom:1px solid rgb(20 33 15/.1)}.results-heading p{font-size:.7rem;color:#69735f}.job-result{display:flex;width:100%;gap:.8rem;padding:1rem;text-align:left}.job-result:hover{background:#f7fbf4}.job-result.is-selected{background:#eefbf4;box-shadow:inset 3px 0 #1f9d6a}.company-mark{display:grid;width:2.55rem;height:2.55rem;flex:none;place-items:center;border-radius:.65rem;background:#10210d;color:#b4ef6f;font-size:.72rem;font-weight:900}.fit-score{margin-left:auto;color:#15724e;text-align:right}.fit-score small{display:block;font-size:.6rem}.detail-heading{display:flex;justify-content:space-between;gap:1rem;padding:1.5rem;border-bottom:1px solid rgb(20 33 15/.1)}.icon-button{width:2.75rem;border:1px solid rgb(20 33 15/.13);border-radius:.6rem}.icon-button[aria-pressed=true]{background:#e7ffd2}.primary-action{min-height:2.5rem;white-space:nowrap;border-radius:.6rem;background:#10210d;padding:.55rem .85rem;color:white;font-size:.75rem;font-weight:800;line-height:1}.primary-action:disabled{background:#dff1cf;color:#33551a}.handoff{display:flex;align-items:center;justify-content:space-between;gap:1rem;background:#fff7eb;padding:1rem 1.5rem}.tool-tabs{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid rgb(20 33 15/.1)}.tool-tab{padding:1rem;color:#69735f;font-size:.8rem;font-weight:800}.tool-tab.is-active{border-bottom:2px solid #1f9d6a;color:#14210f}.detail-body{padding:1.5rem}.fit-summary{display:flex;align-items:center;gap:1rem}.fit-ring{display:grid;width:4.5rem;height:4.5rem;flex:none;place-items:center;align-content:center;border:6px solid #b4ef6f;border-right-color:#e7ffd2;border-radius:50%}.fit-ring span{font-size:.6rem}.skill-tag{border-radius:.45rem;background:#eefbf4;padding:.4rem .6rem;color:#15724e;font-size:.72rem;font-weight:750}.document-row{display:flex;align-items:center;gap:.8rem;margin-top:1.25rem;border-block:1px solid rgb(20 33 15/.1);padding:1rem 0}.document-icon{display:grid;width:2.7rem;height:3.3rem;place-items:center;border-radius:.4rem;background:#10210d;color:white;font-size:.65rem;font-weight:900}@media(max-width:1023px){.jobs-heading,.jobs-controls{align-items:stretch;flex-direction:column}.jobs-workspace{display:block}.job-detail{border-top:1px solid rgb(20 33 15/.1)}}@media(max-width:639px){.detail-heading,.handoff{flex-direction:column}.tool-tabs{grid-template-columns:1fr}.jobs-heading>div:last-child{align-items:stretch;flex-direction:column}}
</style>
