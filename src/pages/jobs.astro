---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { loadScoutData, profileById } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const isAi = Astro.locals.scoutProfile?.assistant_type === "ai";
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const activeProfiles = data.jobProfiles.filter((profile) => profile.active);
const visibleJobs = isAi ? data.jobs.filter((job) => job.source !== "fastapply_job_board") : data.jobs;
const jobs = visibleJobs.map(job => {
  const profile = profileById(data, job.job_profile_id);
  const fitAnalysis = job.fit_analysis as { matched_skills?: string[]; summary?: string };
  const primaryResume = data.resumes.find((resume) => resume.id === profile?.resume_ids?.[0]);
  const hasApplication = data.applications.some((application) => application.job_id === job.id);
  return {
    ...job,
    posted: new Intl.RelativeTimeFormat("en",{numeric:"auto"}).format(Math.round((new Date(job.created_at).getTime()-Date.now())/86400000),"day"),
    initials: job.company.split(/\s+/).map((part:string)=>part[0]).join("").slice(0,2).toUpperCase(),
    resume: primaryResume?.name || "Resume must be attached to this profile",
    summary: job.description || "No job description was provided. Open the original listing or paste the description when adding the job.",
    skills: Array.isArray(fitAnalysis?.matched_skills) && fitAnalysis.matched_skills.length
      ? fitAnalysis.matched_skills
      : (profile?.target_roles.length ? profile.target_roles : ["Role fit", "Experience", "Location"]),
    fitSummary: fitAnalysis?.summary || (job.fit_status === "failed"
      ? "Scout could not score this role yet. Retry the analysis."
      : "Scout is comparing this role with your profile and resume."),
    profileName: profile?.name || "General profile",
    canEdit: !hasApplication,
    assistantName: job.assistant_type === "human"
      ? (data.profile.assistant_type === "human" && data.profile.assistant_name ? data.profile.assistant_name : "Human Assistant")
      : "Scout AI",
  };
});
const first = jobs[0] || null;
const firstIsQueued = first ? ["delegated", "preparing", "applied", "interview"].includes(first.status) : false;
---
<App title="Jobs | Scout" active="jobs">
  <header class="jobs-heading"><div><p class="text-sm font-bold text-signal-700">Jobs workspace</p><h1 class="mt-1 text-2xl font-extrabold">Find work worth applying to.</h1></div><div class="flex w-full items-center justify-end gap-3 lg:w-auto"><label class="jobs-search" for="job-search"><span>⌕</span><input id="job-search" type="search" placeholder="Search title, company, or skill" autocomplete="off"/></label>{!isAi && <AddJobDialog profiles={activeProfiles}/>}</div></header>
  <div class="jobs-controls"><div class="jobs-tabs" role="tablist"><button class="job-tab is-active" data-status="all">All <span>{jobs.length}</span></button><button class="job-tab" data-status="saved">Saved <span>{jobs.filter(j=>j.is_saved).length}</span></button><button class="job-tab" data-status="delegated">Delegated <span>{jobs.filter(j=>j.status==="delegated"||j.status==="preparing").length}</span></button><button class="job-tab" data-status="applied">Applied <span>{jobs.filter(j=>j.status==="applied"||j.status==="interview").length}</span></button></div><label class="text-xs font-bold text-ink-muted">Jobs for <select id="profile-filter" class="jobs-select"><option value="all">All profiles</option>{data.jobProfiles.map(profile=><option value={profile.id}>{profile.name}</option>)}</select></label></div>
  {first ? <div class="jobs-workspace">
    <aside class="jobs-results"><div class="results-heading"><div><strong id="result-count">{jobs.length} jobs</strong><p>{isAi ? "Matched through FastApply" : "From your assistant queue"}</p></div><span>☷</span></div><div id="job-results" class="divide-y divide-ink/10">{jobs.map((job,index)=><button type="button" class:list={["job-result",index===0&&"is-selected"]} data-index={index} data-id={job.id} data-status={job.status} data-saved={job.is_saved ? "true" : "false"} data-profile={job.job_profile_id || ""} data-search={`${job.title} ${job.company} ${job.skills.join(" ")}`.toLowerCase()}><span class="company-mark">{job.initials}</span><span class="min-w-0 flex-1"><strong class="block truncate">{job.title}</strong><span class="mt-1 block truncate text-xs text-ink-soft">{job.company}</span><span class="mt-2 block text-xs text-ink-muted">{job.location || "Location not set"} · {job.posted}</span></span><span class="fit-score"><strong>{job.fit_status === "complete" ? `${job.fit_score}%` : "Scoring…"}</strong><small>{job.fit_status === "failed" ? "unavailable" : "fit"}</small></span></button>)}</div><div id="jobs-empty" class="hidden p-8 text-center"><strong>No jobs found.</strong><p class="mt-2 text-sm text-ink-muted">Try another search or profile.</p></div></aside>
    <section class="job-detail"><header class="detail-heading"><div class="min-w-0"><p class="text-sm text-ink-muted"><strong id="detail-company" class="text-ink">{first.company}</strong> · <span id="detail-posted">{first.posted}</span></p><h2 id="detail-title" class="mt-2 text-3xl font-extrabold">{first.title}</h2><p id="detail-location" class="mt-2 text-sm text-ink-soft">{first.location}</p></div><div class="detail-actions"><button id="save-job" class="icon-button" aria-label="Save job" aria-pressed={first.is_saved ? "true" : "false"}>{first.is_saved ? "♥" : "♡"}</button><button id="delegate-job" class="primary-action" disabled={firstIsQueued}>{firstIsQueued ? "In assistant queue ✓" : `Send to ${first.assistantName} →`}</button></div></header>
      <div class="handoff"><div><p id="assistant-type" class="text-xs font-bold text-human-700">{first.assistant_type.toUpperCase()} ASSISTANT</p><h3 class="mt-1 text-lg font-extrabold"><span id="assistant-name">{first.assistantName}</span> can handle this application.</h3><p class="mt-1 text-sm text-ink-soft">Your profile and resume rules stay attached to the job.</p></div><div class="text-right text-xs font-bold text-ink-muted">Using profile<strong id="profile-name" class="mt-1 block text-sm text-ink">{first.profileName}</strong></div></div>
      <div class="tool-tabs"><button class="tool-tab is-active" data-tool="fit">◎ Fit analysis</button><button class="tool-tab" data-tool="resume">▤ Resume</button><button class="tool-tab" data-tool="answers">☷ Answer plan</button></div>
      <div class="detail-body"><section id="fit-panel" class="tool-panel"><div class="fit-summary"><div id="detail-score-ring" class="fit-ring" style={`--match-score:${first.fit_status === "complete" ? first.fit_score : 0}`}><strong id="detail-score">{first.fit_status === "complete" ? first.fit_score : "—"}</strong><span id="detail-score-label">{first.fit_status === "complete" ? "% fit" : "analyzing"}</span></div><div><h3 class="text-lg font-extrabold">Profile match</h3><p id="fit-summary-text" class="mt-1 text-sm leading-relaxed text-ink-soft">{first.fitSummary}</p></div></div><h3 class="mt-7 font-extrabold">Profile targets</h3><div id="detail-skills" class="mt-3 flex flex-wrap gap-2">{first.skills.map(skill=><span class="skill-tag is-match">✓ {skill}</span>)}</div></section><section id="resume-panel" class="tool-panel hidden"><h3 class="text-lg font-extrabold">Resume Scout will use</h3><p class="mt-2 text-sm text-ink-soft">Your job profile controls whether Scout tailors a copy or keeps your original.</p><div class="document-row"><span class="document-icon">PDF</span><strong id="detail-resume" class="block truncate">{first.resume}</strong></div></section><section id="answers-panel" class="tool-panel hidden"><h3 class="text-lg font-extrabold">Application answer plan</h3><p class="mt-2 text-sm text-ink-soft">Known answers come from your profile. A Human Assistant asks in WhatsApp before ambiguous answers.</p></section><section class="role-section mt-8 border-t border-ink/10 pt-7"><h3 class="text-lg font-extrabold">About the role</h3><p id="detail-summary" class="job-description-scroll mt-3 w-full whitespace-pre-line text-sm leading-7 text-ink-soft">{first.summary}</p><div class="mt-5 flex flex-wrap items-center justify-between gap-3"><a id="original-link" href={first.external_url || "#"} target="_blank" rel="noopener noreferrer" class:list={["inline-flex text-sm font-extrabold text-brand-700",!first.external_url&&"hidden"]}>Open original listing →</a><div id="job-manage-actions" class:list={["flex gap-3",!first.canEdit&&"hidden"]}><button id="edit-job" type="button" class="text-sm font-bold text-brand-800">Edit details</button><button id="delete-job" type="button" class="text-sm font-bold text-red-700">Delete job</button></div></div></section></div>
    </section>
  </div> : <div class="mt-8 rounded-xl bg-white p-12 text-center shadow-card"><h2 class="text-2xl font-extrabold">{isAi ? "Scout is finding jobs for you" : "Your jobs workspace is ready"}</h2><p class="mx-auto mt-3 max-w-md text-ink-soft">{isAi ? "Matching jobs will appear here automatically based on your Scout AI profile." : "Add a job you found, choose a profile, and send it to your Human Assistant."}</p>{!isAi && <div class="mt-6"><AddJobDialog profiles={activeProfiles} id="jobs-empty-add"/></div>}</div>}
  <dialog id="edit-job-dialog" class="w-[min(92vw,38rem)] rounded-2xl bg-white p-0 text-ink shadow-lift backdrop:bg-ink/55"><form id="edit-job-form" class="p-6 sm:p-8"><input type="hidden" name="id"/><input type="hidden" name="action" value="edit"/><div class="flex items-start justify-between gap-4"><div><h2 class="text-2xl font-extrabold">Edit saved job</h2><p class="mt-2 text-sm text-ink-soft">Changes trigger a fresh profile match score.</p></div><button type="button" data-close-edit class="grid h-10 w-10 place-items-center rounded-full bg-surface" aria-label="Close job editor">×</button></div><div class="mt-6 grid gap-4 sm:grid-cols-2"><label class="text-sm font-bold">Job title<input required maxlength="180" name="title" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold">Company<input required maxlength="180" name="company" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold">Location<input maxlength="240" name="location" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold">Job profile<select name="job_profile_id" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 font-normal">{data.jobProfiles.map(profile=><option value={profile.id}>{profile.name}</option>)}</select></label><label class="text-sm font-bold sm:col-span-2">Job URL<input name="external_url" type="url" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label><label class="text-sm font-bold sm:col-span-2">Description<textarea name="description" rows="6" class="mt-2 w-full resize-y rounded-xl border border-ink/15 px-4 py-3 font-normal"></textarea></label></div><p data-edit-error class="mt-4 hidden rounded-lg bg-red-50 p-3 text-sm font-bold text-red-700" role="alert"></p><div class="mt-6 flex justify-end gap-3"><button type="button" data-close-edit class="rounded-full px-5 py-3 text-sm font-bold">Cancel</button><button type="submit" class="rounded-full bg-ink px-5 py-3 text-sm font-extrabold text-white">Save and rescore</button></div></form></dialog>
  <script define:vars={{ jobs, isAi }}>
    const results=[...document.querySelectorAll(".job-result")],statusTabs=[...document.querySelectorAll(".job-tab")],toolTabs=[...document.querySelectorAll(".tool-tab")],search=document.querySelector("#job-search"),profileFilter=document.querySelector("#profile-filter");let status="all",selected=jobs[0];
    function filter(){const query=search?.value.trim().toLowerCase()||"",profile=profileFilter?.value||"all";let count=0;results.forEach(button=>{const group=status==="all"||(status==="saved"&&button.dataset.saved==="true")||(status!=="saved"&&button.dataset.status===status)||(status==="delegated"&&button.dataset.status==="preparing")||(status==="applied"&&button.dataset.status==="interview");const show=group&&(profile==="all"||button.dataset.profile===profile)&&(!query||(button.dataset.search || "").includes(query));button.classList.toggle("hidden",!show);if(show)count++});document.querySelector("#jobs-empty")?.classList.toggle("hidden",count!==0);if(document.querySelector("#result-count"))document.querySelector("#result-count").textContent=count+(count===1?" job":" jobs")}
    function render(job){selected=job;document.querySelector("#detail-company").textContent=job.company;document.querySelector("#detail-posted").textContent=job.posted;document.querySelector("#detail-title").textContent=job.title;document.querySelector("#detail-location").textContent=job.location||"Location not set";document.querySelector("#detail-score").textContent=job.fit_status==="complete"?job.fit_score:"—";document.querySelector("#detail-score-ring").style.setProperty("--match-score",String(job.fit_status==="complete"?job.fit_score:0));document.querySelector("#detail-score-label").textContent=job.fit_status==="complete"?"% fit":job.fit_status==="failed"?"unavailable":"analyzing";document.querySelector("#fit-summary-text").textContent=job.fitSummary;document.querySelector("#detail-summary").textContent=job.summary;document.querySelector("#detail-resume").textContent=job.resume;document.querySelector("#profile-name").textContent=job.profileName;document.querySelector("#assistant-name").textContent=job.assistantName;document.querySelector("#assistant-type").textContent=job.assistant_type.toUpperCase()+" ASSISTANT";const skills=document.querySelector("#detail-skills");skills.replaceChildren(...job.skills.map(skill=>{const tag=document.createElement("span");tag.className="skill-tag is-match";tag.textContent="✓ "+skill;return tag}));const link=document.querySelector("#original-link");link.href=job.external_url||"#";link.classList.toggle("hidden",!job.external_url);const done=["delegated","preparing","applied","interview"].includes(job.status),delegate=document.querySelector("#delegate-job");delegate.textContent=done?"In assistant queue ✓":"Send to "+job.assistantName+" →";delegate.disabled=done;document.querySelector("#job-manage-actions").classList.toggle("hidden",!job.canEdit);document.querySelector("#save-job").setAttribute("aria-pressed",job.is_saved?"true":"false");document.querySelector("#save-job").textContent=job.is_saved?"♥":"♡"}
    async function setStatus(next){const response=await fetch("/api/app/jobs",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify({id:selected.id,status:next})});const data=await response.json();if(!response.ok){window.scoutToast?.(data.error||"Could not update job",true);return false}selected.status=next;const button=results.find(item=>item.dataset.id===selected.id);if(button)button.dataset.status=next;window.scoutToast?.(next==="delegated"?"Job sent to your assistant":"Job updated");return true}
    results.forEach(button=>button.addEventListener("click",()=>{results.forEach(item=>item.classList.remove("is-selected"));button.classList.add("is-selected");render(jobs[Number(button.dataset.index)])}));
    statusTabs.forEach(tab=>tab.addEventListener("click",()=>{status=tab.dataset.status;statusTabs.forEach(item=>item.classList.toggle("is-active",item===tab));filter()}));search?.addEventListener("input",filter);profileFilter?.addEventListener("change",filter);
    toolTabs.forEach(tab=>tab.addEventListener("click",()=>{toolTabs.forEach(item=>item.classList.toggle("is-active",item===tab));document.querySelectorAll(".tool-panel").forEach(panel=>panel.classList.add("hidden"));document.querySelector("#"+tab.dataset.tool+"-panel")?.classList.remove("hidden")}));
    document.querySelector("#delegate-job")?.addEventListener("click",async event=>{event.currentTarget.disabled=true;if(isAi){try{const response=await fetch("/api/app/ai-jobs",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({...selected,localId:selected.id,profileId:selected.job_profile_id,url:selected.external_url})});const data=await response.json();if(!response.ok)throw new Error(data.error||"Could not queue application");selected.status="delegated";render(selected);window.scoutToast?.("Scout is applying to this job.")}catch(error){event.currentTarget.disabled=false;window.scoutToast?.(error instanceof Error?error.message:"Could not queue application",true)}}else if(await setStatus("delegated"))render(selected);else event.currentTarget.disabled=false});
    document.querySelector("#save-job")?.addEventListener("click",async event=>{
      const button=event.currentTarget,job=selected,previous=Boolean(job.is_saved),next=!previous;
      const syncSavedState=(value)=>{job.is_saved=value;button.setAttribute("aria-pressed",value?"true":"false");button.textContent=value?"♥":"♡";const resultButton=results.find(item=>item.dataset.id===job.id);if(resultButton)resultButton.dataset.saved=value?"true":"false";const savedCount=document.querySelector(".job-tab[data-status=saved] span");if(savedCount)savedCount.textContent=String(results.filter(item=>item.dataset.saved==="true").length);filter()};
      syncSavedState(next);
      button.disabled=true;
      try{
        const response=await fetch("/api/app/jobs",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify({id:job.id,is_saved:next})});
        const data=await response.json();
        if(!response.ok)throw new Error(data.error||"Could not save job");
        window.scoutToast?.(next?"Job saved":"Job removed from saved");
      }catch(error){
        syncSavedState(previous);
        window.scoutToast?.(error instanceof Error?error.message:"Could not save job",true);
      }finally{button.disabled=false}
    });
    const editDialog=document.querySelector("#edit-job-dialog"),editForm=document.querySelector("#edit-job-form");
    document.querySelector("#edit-job")?.addEventListener("click",()=>{if(!selected?.canEdit)return;editForm.reset();editForm.elements.id.value=selected.id;editForm.elements.title.value=selected.title;editForm.elements.company.value=selected.company;editForm.elements.location.value=selected.location||"";editForm.elements.job_profile_id.value=selected.job_profile_id||"";editForm.elements.external_url.value=selected.external_url||"";editForm.elements.description.value=selected.description||"";editForm.querySelector("[data-edit-error]").classList.add("hidden");editDialog.showModal()});
    editDialog?.querySelectorAll("[data-close-edit]").forEach(button=>button.addEventListener("click",()=>editDialog.close()));
    editDialog?.addEventListener("click",event=>{if(event.target===editDialog)editDialog.close()});
    editForm?.addEventListener("submit",async event=>{event.preventDefault();const button=editForm.querySelector("[type=submit]"),error=editForm.querySelector("[data-edit-error]");button.disabled=true;button.textContent="Saving and scoring…";error.classList.add("hidden");try{const body=Object.fromEntries(new FormData(editForm).entries());const response=await fetch("/api/app/jobs",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify(body)});const data=await response.json();if(!response.ok)throw new Error(data.error||"Could not update job");location.reload()}catch(reason){error.textContent=reason instanceof Error?reason.message:"Could not update job";error.classList.remove("hidden");button.disabled=false;button.textContent="Save and rescore"}});
    document.querySelector("#delete-job")?.addEventListener("click",async()=>{if(!selected?.canEdit||!confirm("Delete this saved job?"))return;const button=document.querySelector("#delete-job");button.disabled=true;const response=await fetch("/api/app/jobs?id="+encodeURIComponent(selected.id),{method:"DELETE"});const data=await response.json();if(response.ok)location.reload();else{button.disabled=false;window.scoutToast?.(data.error||"Could not delete job",true)}});
    const pendingJobs=jobs.filter(job=>job.fit_status==="pending").slice(0,3);
    if(pendingJobs.length){(async()=>{let changed=false;for(const job of pendingJobs){try{const response=await fetch("/api/app/job-score",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({id:job.id})});const data=await response.json();if(response.ok&&data.job){Object.assign(job,data.job);changed=true}}catch{}}if(changed)window.location.reload()})()}
  </script>
</App>
<style>
.jobs-heading{display:flex;align-items:end;justify-content:space-between;gap:1.5rem}.jobs-search{display:flex;width:min(100%,25rem);align-items:center;gap:.65rem;border:1px solid rgb(20 33 15/.14);border-radius:999px;background:white;padding:.7rem 1rem}.jobs-search input{min-width:0;width:100%;outline:0}.jobs-controls{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:1.5rem;border-bottom:1px solid rgb(20 33 15/.1);padding-bottom:.75rem}.jobs-tabs{display:flex;gap:.25rem;overflow:auto}.job-tab{border-radius:999px;padding:.55rem .9rem;color:#69735f;font-size:.8rem;font-weight:800}.job-tab.is-active{background:#10210d;color:white}.jobs-select{margin-left:.5rem;border:1px solid rgb(20 33 15/.12);border-radius:.6rem;background:white;padding:.58rem .75rem;font-size:.75rem}.jobs-workspace{display:grid;grid-template-columns:23rem minmax(0,1fr);height:calc(100vh - 13.5rem);min-height:36rem;margin-top:1rem;overflow:hidden;border-radius:.875rem;background:white;box-shadow:0 8px 24px -12px rgb(13 27 42/.12)}.jobs-results{display:flex;min-height:0;flex-direction:column;overflow:hidden;border-right:1px solid rgb(20 33 15/.1)}#job-results{min-height:0;flex:1;overflow-y:auto;overscroll-behavior:contain;scrollbar-gutter:stable}.job-detail{display:flex;min-height:0;flex-direction:column;overflow:hidden}.results-heading{display:flex;justify-content:space-between;padding:1rem;border-bottom:1px solid rgb(20 33 15/.1)}.results-heading p{font-size:.7rem;color:#69735f}.job-result{display:flex;width:100%;gap:.8rem;padding:1rem;text-align:left}.job-result:hover{background:#f7fbf4}.job-result.is-selected{background:#eefbf4;box-shadow:inset 3px 0 #1f9d6a}.company-mark{display:grid;width:2.55rem;height:2.55rem;flex:none;place-items:center;border-radius:.65rem;background:#10210d;color:#b4ef6f;font-size:.72rem;font-weight:900}.fit-score{margin-left:auto;color:#15724e;text-align:right}.fit-score small{display:block;font-size:.6rem}.detail-heading{display:flex;justify-content:space-between;gap:1rem;padding:1.5rem;border-bottom:1px solid rgb(20 33 15/.1)}.detail-actions{display:flex;flex:none;flex-flow:row nowrap;align-items:stretch;align-self:flex-start;gap:.5rem}.icon-button{width:2.5rem;min-width:2.5rem;min-height:2.25rem;border:1px solid rgb(20 33 15/.13);border-radius:.6rem}.icon-button[aria-pressed=true]{background:#e7ffd2}.primary-action{min-height:2.25rem;white-space:nowrap;border-radius:.6rem;background:#10210d;padding:.45rem .7rem;color:white;font-size:.75rem;font-weight:800;line-height:1}.primary-action:disabled{background:#dff1cf;color:#33551a}.handoff{display:flex;align-items:center;justify-content:space-between;gap:1rem;background:#fff7eb;padding:1rem 1.5rem}.tool-tabs{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid rgb(20 33 15/.1)}.tool-tab{padding:1rem;color:#69735f;font-size:.8rem;font-weight:800}.tool-tab.is-active{border-bottom:2px solid #1f9d6a;color:#14210f}.detail-body{display:flex;min-height:0;flex:1;flex-direction:column;overflow:hidden;padding:1.5rem}.tool-panel{flex:none}.role-section{display:flex;min-height:0;flex:1;flex-direction:column}.role-section>div:last-child{flex:none}.fit-summary{display:flex;align-items:center;gap:1rem}.fit-ring{position:relative;display:grid;width:4.5rem;height:4.5rem;flex:none;place-items:center;align-content:center;border-radius:50%;background:conic-gradient(from -90deg,#1f9d6a calc(var(--match-score,0)*1%),#e7ffd2 0)}.fit-ring::before{position:absolute;inset:6px;border-radius:50%;background:#fff;content:""}.fit-ring strong,.fit-ring span{position:relative;z-index:1}.fit-ring span{font-size:.6rem}.skill-tag{border-radius:.45rem;background:#eefbf4;padding:.4rem .6rem;color:#15724e;font-size:.72rem;font-weight:750}.document-row{display:flex;align-items:center;gap:.8rem;margin-top:1.25rem;border-block:1px solid rgb(20 33 15/.1);padding:1rem 0}.document-icon{display:grid;width:2.7rem;height:3.3rem;place-items:center;border-radius:.4rem;background:#102