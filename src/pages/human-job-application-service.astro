---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import ProductScreenshot from "../components/ProductScreenshot.astro";
import MarketingCTA from "../components/MarketingCTA.astro";
---
<Base title="Human Job Application Service: We Apply for You" description="Hire a dedicated human job application assistant to find roles, tailor resumes, apply on your behalf, and share submission evidence in WhatsApp.">
  <section class="relative min-h-[720px] overflow-hidden bg-brand-950 text-white"><img src="/assets/scout-human-review.webp" alt="A Scout human assistant reviewing an important application" width="1400" height="760" class="absolute inset-0 h-full w-full object-cover object-[35%_center]" /><div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,33,13,.16),rgba(16,33,13,.34)_48%,rgba(16,33,13,.98)_72%)]"></div><Container class="relative flex min-h-[720px] items-center justify-end py-20"><div class="max-w-xl"><span class="rounded-full bg-human-500 px-3 py-1.5 text-sm font-bold text-white">Human Assistant · bundles from $299</span><h1 class="mt-6 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] text-white sm:text-7xl">A human job application assistant who applies for you.</h1><p class="mt-6 text-lg leading-relaxed text-white/72">For busy or exhausted job seekers: your assigned assistant finds suitable roles, applies on your behalf, works with you in WhatsApp, and saves detailed evidence of every submission.</p><Button href="/book-call" size="lg" class="mt-8 rounded-full bg-brand-300 text-ink">Book a free strategy call</Button><p class="mt-3 text-sm font-semibold text-white/55">15 minutes · No commitment</p></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">What your dedicated assistant handles.</h2></div><div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"><div class="rounded-2xl bg-human-50 p-6"><strong>Senior roles</strong><p class="mt-2 text-sm text-ink-soft">Leadership scope and complex experience.</p></div><div class="rounded-2xl bg-surface p-6"><strong>Career pivots</strong><p class="mt-2 text-sm text-ink-soft">Transferable skills need a clear story.</p></div><div class="rounded-2xl bg-human-50 p-6"><strong>Unusual questions</strong><p class="mt-2 text-sm text-ink-soft">Context beats a generic answer.</p></div><div class="rounded-2xl bg-surface p-6"><strong>Priority companies</strong><p class="mt-2 text-sm text-ink-soft">A second set of eyes before submission.</p></div></div></Container></section>
  <section class="bg-surface py-20 sm:py-28"><Container><div class="grid items-center gap-10 lg:grid-cols-2"><div><p class="text-lg font-bold text-human-700">A visible review loop</p><h2 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">See the note. Approve the change. Then it goes out.</h2><p class="mt-5 text-lg leading-relaxed text-ink-soft">Human assistance is not a black box. Open each application to see the resume used and screenshots of important form answers, then message your assistant in WhatsApp.</p></div><ProductScreenshot variant="human" /></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="grid items-center gap-10 lg:grid-cols-2"><div class="relative min-h-[470px] overflow-hidden rounded-2xl"><img src="/assets/scout-swipe-review.webp" alt="A job seeker reviewing Scout matches on a phone" width="1400" height="760" loading="lazy" class="absolute inset-0 h-full w-full object-cover" /></div><div><p class="text-lg font-bold text-brand-700">Your search still feels like yours</p><h2 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">Review from your phone without doing the forms.</h2><p class="mt-5 text-lg leading-relaxed text-ink-soft">Approve matches, read assistant notes, and check receipts wherever you are. Scout handles the application work behind the decision.</p></div></div></Container></section>
  <MarketingCTA title="Meet the person who will run your application search." body="Book a short call so we can understand your targets, assign the right assistant, and prepare your WhatsApp group." />
</Base>
