---
import Shell from "../../layouts/Shell.astro";
import Container from "../../components/Container.astro";
import Button from "../../components/Button.astro";
import AppStoreBadges from "../../components/AppStoreBadges.astro";
import DownloadQR from "../../components/DownloadQR.astro";
import SwipeHero from "../../components/islands/SwipeHero.tsx";
import { SITE, TIERS, STATS } from "../../config/site";

const platforms = ["Workday", "Greenhouse", "Lever", "LinkedIn", "Indeed", "Glassdoor"];

const steps = [
  {
    n: "01",
    title: "Upload your resume once",
    body: "Scout reads your experience, skills, and the kind of role you want. No retyping it into a hundred forms ever again.",
  },
  {
    n: "02",
    title: "It finds every match",
    body: "Scout scans the boards and company systems all day and ranks every open role by how well it actually fits you.",
  },
  {
    n: "03",
    title: "You swipe, it applies",
    body: "Each application goes out with a resume and cover letter tailored to that exact job. You just swipe right.",
  },
];

const modes = [
  {
    title: "Swipe Apply",
    body: "Review ranked matches like a deck of cards. Swipe right and Scout applies with tailored documents. A week of applications in minutes.",
    badge: "You stay in control",
  },
  {
    title: "First Apply",
    body: "Scout watches for new postings and applies within minutes, around the clock. Early applicants get far more interviews.",
    badge: "Applied 3 minutes after posting",
  },
];

const safety = [
  { title: "You approve every application", body: "Nothing goes out under your name unless you swipe right on it." },
  { title: "Human-like rate limits", body: "Applications are paced to protect your LinkedIn, email, and ATS accounts from being flagged." },
  { title: "Tailored, never templated", body: "A unique resume and cover letter per job. The opposite of the spam recruiters filter out." },
];

const appLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `${SITE.name}: ${SITE.tagline}`,
  operatingSystem: "iOS, Android",
  applicationCategory: "BusinessApplication",
  description: SITE.description,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: STATS.rating, ratingCount: STATS.ratingCount.replace(/[^0-9]/g, "") },
};
---
<Shell title={`${SITE.name}: ${SITE.tagline}`} description={SITE.description}>
  <!-- ================= DARK HERO ZONE (v0 / Vercel) ================= -->
  <div class="relative overflow-hidden bg-[#0a0f1a] text-white">
    <!-- subtle masked dot grid + brand glow backdrop -->
    <div class="bg-grid absolute inset-0 -z-10 opacity-40"></div>
    <div class="glow-brand absolute left-1/2 top-[-10%] -z-10 h-[520px] w-[820px] -translate-x-1/2 blur-2xl"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

    <!-- Top nav (dark themed, over the hero) -->
    <header class="relative z-20">
      <Container class="flex h-20 items-center justify-between">
        <a href="/" class="font-display text-lg font-bold tracking-tight text-white">Scout</a>
        <Button href="/download" variant="secondary" class="border-white/15 bg-white/10 text-white hover:border-white/30 hover:bg-white/15">
          Download
        </Button>
      </Container>
    </header>

    <!-- Hero -->
    <section class="relative">
      <Container class="grid items-center gap-12 pb-24 pt-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12 lg:pb-32 lg:pt-16">
        <div class="reveal">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-sm font-medium text-brand-200 backdrop-blur">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-70"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
            </span>
            Live on iOS &amp; Android
          </span>
          <h1 class="mt-6 font-display text-[3rem] font-bold leading-[1.0] tracking-tight text-white sm:text-6xl lg:text-[4.4rem]">
            Get a job <br class="hidden sm:block" />while you <span class="text-brand-400">sleep.</span>
          </h1>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-white/65">
            Scout finds every job matching your resume and applies for you with a tailored resume and cover letter. Just swipe.
          </p>
          <div class="mt-9 flex flex-col items-start gap-5 sm:flex-row sm:items-center">
            <AppStoreBadges size="lg" />
            <DownloadQR class="hidden border-white/10 bg-white/5 sm:inline-flex" label="Scan to install" />
          </div>
        </div>

        <!-- Live app preview in a phone frame, glowing -->
        <div class="reveal relative mx-auto w-full max-w-[400px]" style="--reveal-delay:120ms">
          <div class="glow-brand absolute -inset-12 -z-10 blur-2xl"></div>
          <div class="device">
            <div class="device-screen px-4 pb-6 pt-5">
              <div class="mb-4 flex items-center justify-between px-1">
                <span class="font-display text-sm font-bold text-ink">Scout</span>
                <span class="rounded-full bg-white px-2.5 py-1 text-[0.7rem] font-medium text-ink-soft shadow-card">128 matches</span>
              </div>
              <SwipeHero client:load />
            </div>
          </div>
        </div>
      </Container>

      <!-- Platform strip, anchored to the bottom of the dark hero -->
      <div class="border-t border-white/10 bg-white/[0.02]">
        <Container class="py-7">
          <p class="text-center text-sm text-white/45">Applies for you across every major board and applicant tracking system</p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-3 gap-y-3">
            {platforms.map((p) => (
              <span class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3.5 py-2">
                <span class="grid h-6 w-6 place-items-center rounded-md bg-brand-500/20 text-[0.7rem] font-bold text-brand-200">{p.slice(0, 2)}</span>
                <span class="text-sm font-medium text-white/80">{p}</span>
              </span>
            ))}
          </div>
        </Container>
      </div>
    </div>
    <!-- soft seam fade into the light body -->
    <div class="h-px w-full bg-gradient-to-b from-[#0a0f1a] to-transparent"></div>
  </div>

  <!-- ================= LIGHT BODY ZONE ================= -->
  <main class="bg-surface">
    <!-- ===== HOW IT WORKS: Optimus-style large numbered sections ===== -->
    <section>
      <Container class="py-24 sm:py-32">
        <div class="reveal max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">How it works</p>
          <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight sm:text-[2.7rem]">
            Set it up once. Then it runs your search for you.
          </h2>
        </div>

        <div class="mt-16 divide-y divide-black/5 border-t border-black/5">
          {steps.map((s, i) => (
            <div class="reveal grid items-center gap-8 py-12 lg:grid-cols-[auto_1fr_auto] lg:gap-14" style={`--reveal-delay:${i * 90}ms`}>
              <span class="font-display text-5xl font-bold leading-none text-brand-200 sm:text-7xl">{s.n}</span>
              <div class="max-w-xl">
                <h3 class="font-display text-2xl font-bold tracking-tight sm:text-3xl">{s.title}</h3>
                <p class="mt-3 text-lg leading-relaxed text-ink-soft">{s.body}</p>
              </div>
              <div class="hidden h-28 w-28 shrink-0 place-items-center rounded-3xl border border-black/5 bg-surface-soft text-brand-600 shadow-card lg:grid">
                {i === 0 && (
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
                )}
                {i === 1 && (
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/><path d="m9 11 1.5 1.5L14 9"/></svg>
                )}
                {i === 2 && (
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h13l-3-3"/><path d="M21 17H8l3 3"/><path d="m19 9 1.5 1.5L23 8"/></svg>
                )}
              </div>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- ===== TWO MODES (contrasting card duo) ===== -->
    <section class="bg-surface-soft">
      <Container class="py-24 sm:py-32">
        <div class="reveal max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">Two modes</p>
          <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight sm:text-[2.7rem]">
            Built for how you actually job hunt.
          </h2>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {modes.map((m, i) => (
            <div class="reveal group flex flex-col rounded-3xl border border-black/5 bg-white p-8 shadow-card transition-shadow hover:shadow-lift" style={`--reveal-delay:${i * 90}ms`}>
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-600 text-white">
                {i === 0 ? (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h13l-3-3"/><path d="M21 17H8l3 3"/></svg>
                ) : (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
                )}
              </span>
              <h3 class="mt-6 font-display text-2xl font-bold tracking-tight">{m.title}</h3>
              <p class="mt-3 max-w-sm leading-relaxed text-ink-soft">{m.body}</p>
              <span class="mt-6 inline-flex w-fit items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>{m.badge}
              </span>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- ===== SAFETY (split: statement + checklist) ===== -->
    <section>
      <Container class="py-24 sm:py-32">
        <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
          <div class="reveal lg:sticky lg:top-28 lg:self-start">
            <span class="inline-flex items-center gap-2 rounded-full border border-black/5 bg-surface-soft px-3 py-1 text-sm font-medium text-brand-700">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Safe by design
            </span>
            <h2 class="mt-5 font-display text-3xl font-bold leading-tight tracking-tight sm:text-[2.7rem]">
              Automation you can trust with your name.
            </h2>
            <p class="mt-5 max-w-md text-lg leading-relaxed text-ink-soft">
              The real fear with auto-apply tools is getting flagged or spamming recruiters. Scout is engineered to do the opposite.
            </p>
          </div>
          <ul class="space-y-4">
            {safety.map((s, i) => (
              <li class="reveal flex items-start gap-4 rounded-3xl border border-black/5 bg-white p-7 shadow-card" style={`--reveal-delay:${i * 90}ms`}>
                <span class="mt-0.5 grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-brand-50 text-brand-700">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                <div>
                  <h3 class="font-display text-lg font-bold tracking-tight">{s.title}</h3>
                  <p class="mt-1.5 leading-relaxed text-ink-soft">{s.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </section>

    <!-- ===== PRICING CTA BAND ===== -->
    <section class="bg-surface-soft">
      <Container class="py-24 sm:py-28">
        <div class="reveal mx-auto max-w-2xl text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">Pricing</p>
          <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight sm:text-[2.7rem]">
            Start free. Upgrade when it is landing you interviews.
          </h2>
          <p class="mx-auto mt-4 max-w-md text-lg text-ink-soft">
            Free includes {TIERS[0].features[0].toLowerCase()}. Pro and Max unlock unlimited tailored applications.
          </p>
        </div>
        <div class="mt-14 grid gap-6 md:grid-cols-3">
          {TIERS.map((t, i) => (
            <div
              class={`reveal flex flex-col rounded-3xl border p-8 ${t.featured ? "border-brand-600 bg-white shadow-lift ring-1 ring-brand-600" : "border-black/5 bg-white shadow-card"}`}
              style={`--reveal-delay:${i * 90}ms`}
            >
              <div class="flex items-center justify-between">
                <span class="font-display text-lg font-bold tracking-tight">{t.name}</span>
                {t.featured && <span class="rounded-full bg-brand-600 px-2.5 py-1 text-[0.7rem] font-semibold text-white">Most popular</span>}
              </div>
              <p class="mt-4 font-display text-4xl font-bold tracking-tight">
                {t.priceMonthly === 0 ? "Free" : <>${t.priceMonthly}<span class="text-base font-medium text-ink-muted">/mo</span></>}
              </p>
              <p class="mt-3 text-sm text-ink-soft">{t.blurb}</p>
              <ul class="mt-6 space-y-3 text-sm text-ink-soft">
                {t.features.slice(0, 4).map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg class="mt-0.5 shrink-0 text-brand-600" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
              <Button href="/download" variant={t.featured ? "primary" : "secondary"} class="mt-8 w-full">{t.cta}</Button>
            </div>
          ))}
        </div>
      </Container>
    </section>
  </main>

  <!-- ================= FINAL CTA (dark band, bookend symmetry) ================= -->
  <section class="relative overflow-hidden bg-[#0a0f1a] text-white">
    <div class="bg-grid absolute inset-0 -z-10 opacity-40"></div>
    <div class="glow-brand absolute left-1/2 top-1/2 -z-10 h-[420px] w-[720px] -translate-x-1/2 -translate-y-1/2 blur-2xl"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
    <Container class="py-24 text-center sm:py-32">
      <h2 class="reveal mx-auto max-w-2xl font-display text-3xl font-bold leading-tight tracking-tight text-white sm:text-[2.9rem]">
        Your next job is already out there.
      </h2>
      <p class="reveal mx-auto mt-4 max-w-lg text-lg text-white/60" style="--reveal-delay:90ms">
        Let Scout find it and apply while you get on with your life.
      </p>
      <div class="reveal mt-10 flex flex-col items-center gap-6 sm:flex-row sm:justify-center" style="--reveal-delay:160ms">
        <AppStoreBadges size="lg" class="justify-center" />
        <DownloadQR class="border-white/10 bg-white/5" label="Scan to install" />
      </div>
    </Container>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(appLd)} />
</Shell>
