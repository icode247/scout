---
import Shell from "../../layouts/Shell.astro";
import Container from "../../components/Container.astro";
import Button from "../../components/Button.astro";
import AppStoreBadges from "../../components/AppStoreBadges.astro";
import DownloadQR from "../../components/DownloadQR.astro";
import SwipeHero from "../../components/islands/SwipeHero.tsx";
import { SITE, TIERS, STATS } from "../../config/site";

const platforms = ["Workday", "Greenhouse", "Lever", "LinkedIn", "Indeed", "Glassdoor"];

const steps = [
  {
    n: "01",
    title: "Upload your resume once",
    body: "Scout reads your experience, skills, and what you want. You never re-type it into another form.",
  },
  {
    n: "02",
    title: "It finds every match",
    body: "Scout scans the boards and company systems all day, then ranks roles by how well they fit you.",
  },
  {
    n: "03",
    title: "You swipe, it applies",
    body: "Each application goes out with a resume and cover letter tailored to that exact job. Just swipe right.",
  },
];

const modes = [
  {
    title: "Swipe Apply",
    body: "Review ranked matches like a deck of cards. Swipe right and Scout applies with tailored documents. A week of applications in a few minutes.",
    href: "/human-job-application-service",
  },
  {
    title: "First Apply",
    body: "Scout watches for new postings and applies within minutes, around the clock. Early applicants get far more interviews.",
    href: "/ai-job-application-assistant",
  },
];

const safety = [
  {
    title: "You approve every application",
    body: "Nothing goes out under your name unless you swipe right on it. You stay in control of all of it.",
  },
  {
    title: "Human-like rate limits",
    body: "Applications are paced to protect your LinkedIn, email, and ATS accounts from being flagged.",
  },
  {
    title: "Tailored, never templated",
    body: "A unique resume and cover letter per job. The opposite of the spam recruiters filter out.",
  },
];

// Shared, restrained inline icon set. Stroke 1.5, monochrome, 20px.
const icon = {
  upload:
    "M12 16V4M7 9l5-5 5 5M5 16v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2",
  target:
    "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18ZM12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM12 12h.01",
  swipe: "M5 12h13M13 6l6 6-6 6",
  check: "M20 6 9 17l-5-5",
  arrow: "M5 12h14M13 6l6 6-6 6",
};

const appLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `${SITE.name}: ${SITE.tagline}`,
  operatingSystem: "iOS, Android",
  applicationCategory: "BusinessApplication",
  description: SITE.description,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: STATS.rating,
    ratingCount: STATS.ratingCount.replace(/[^0-9]/g, ""),
  },
};
---
<Shell
  title={`${SITE.name}: Get a job while you sleep`}
  description={SITE.description}
>
  <!-- ============ TOP NAV (minimal, themed) ============ -->
  <header class="sticky top-0 z-50 border-b border-black/5 bg-surface/80 backdrop-blur-md">
    <Container class="flex h-16 items-center justify-between">
      <a href="/" class="font-display text-lg font-bold tracking-tight text-ink">Scout</a>
      <Button href="/download" size="md" variant="primary">Download</Button>
    </Container>
  </header>

  <!-- ============ HERO (asymmetric split, quiet) ============ -->
  <section class="bg-surface">
    <Container class="grid items-center gap-16 py-24 sm:py-28 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12 lg:py-36">
      <div class="reveal">
        <h1 class="font-display text-6xl font-bold leading-[0.98] tracking-[-0.02em] text-ink sm:text-7xl lg:text-[5rem]">
          Get a job while you <span class="text-brand-600">sleep.</span>
        </h1>
        <p class="mt-8 max-w-md text-lg leading-relaxed text-ink-soft">
          Scout finds every job matching your resume and applies for you with a tailored resume and cover letter. Just swipe.
        </p>
        <div class="mt-10 flex flex-col items-start gap-6 sm:flex-row sm:items-center">
          <AppStoreBadges size="lg" />
          <DownloadQR class="hidden sm:inline-flex" label="Scan to install" />
        </div>
      </div>

      <!-- Live app preview in a phone frame -->
      <div class="reveal relative mx-auto w-full max-w-[400px]" style="--reveal-delay:120ms">
        <div class="glow-brand absolute -inset-12 -z-10 blur-2xl"></div>
        <div class="device">
          <div class="device-screen px-4 pb-6 pt-5">
            <div class="mb-4 flex items-center justify-between px-1">
              <span class="font-display text-sm font-bold text-ink">Scout</span>
              <span class="rounded-full bg-white px-2.5 py-1 text-[0.7rem] font-medium text-ink-soft shadow-card">128 matches</span>
            </div>
            <SwipeHero client:load />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============ PLATFORM STRIP (quiet wordmark row) ============ -->
  <section class="border-y border-black/5 bg-surface-soft">
    <Container class="py-14 sm:py-16">
      <p class="text-center text-sm tracking-wide text-ink-muted">
        Applies for you across every major board and applicant tracking system
      </p>
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-5 sm:gap-x-14">
        {platforms.map((p) => (
          <li class="font-display text-lg font-semibold tracking-tight text-ink-soft/70">{p}</li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ============ HOW IT WORKS (3 steps, divided rows) ============ -->
  <section class="bg-surface">
    <Container class="py-28 sm:py-32 lg:py-36">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">How it works</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">
          Set it up once. Then it runs itself.
        </h2>
      </div>

      <div class="mt-16 divide-y divide-black/5 border-y border-black/5">
        {steps.map((s, i) => (
          <div
            class="reveal grid items-baseline gap-4 py-10 sm:grid-cols-[auto_1fr] sm:gap-12 lg:grid-cols-[6rem_1fr_minmax(0,28rem)]"
            style={`--reveal-delay:${i * 90}ms`}
          >
            <span class="font-display text-2xl font-semibold tabular-nums text-ink-muted">{s.n}</span>
            <h3 class="font-display text-2xl font-bold tracking-tight text-ink">{s.title}</h3>
            <p class="text-lg leading-relaxed text-ink-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ============ TWO MODES (asymmetric two-up, hairline cards) ============ -->
  <section class="border-t border-black/5 bg-surface-soft">
    <Container class="py-28 sm:py-32 lg:py-36">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">Two modes</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">
          Two ways to apply, built for how you actually job-hunt.
        </h2>
      </div>

      <div class="mt-16 grid gap-px overflow-hidden rounded-3xl border border-black/5 bg-black/5 md:grid-cols-2">
        {modes.map((m, i) => (
          <a
            href={m.href}
            class="reveal group flex flex-col bg-surface p-10 transition-colors duration-200 hover:bg-surface-soft sm:p-12"
            style={`--reveal-delay:${i * 90}ms`}
          >
            <h3 class="font-display text-3xl font-bold tracking-tight text-ink">{m.title}</h3>
            <p class="mt-5 max-w-sm text-lg leading-relaxed text-ink-soft">{m.body}</p>
            <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink">
              Explore {m.title}
              <svg
                class="transition-transform duration-200 group-hover:translate-x-1"
                width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true"
              ><path d={icon.arrow} /></svg>
            </span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ============ SAFETY (editorial split + checklist) ============ -->
  <section class="border-t border-black/5 bg-surface">
    <Container class="py-28 sm:py-32 lg:py-36">
      <div class="grid gap-16 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20">
        <div class="reveal lg:sticky lg:top-28 lg:self-start">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">Safe by design</p>
          <h2 class="mt-4 font-display text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">
            Automation you can trust with your name.
          </h2>
          <p class="mt-6 max-w-sm text-lg leading-relaxed text-ink-soft">
            The real fear with auto-apply tools is getting flagged or spamming recruiters. Scout is engineered to do the opposite.
          </p>
          <a href="/safety" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink hover:text-brand-600">
            Read about our safety approach
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icon.arrow} /></svg>
          </a>
        </div>

        <ul class="divide-y divide-black/5 border-y border-black/5">
          {safety.map((s, i) => (
            <li class="reveal flex items-start gap-5 py-8" style={`--reveal-delay:${i * 90}ms`}>
              <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-full border border-black/10 text-ink">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icon.check} /></svg>
              </span>
              <div>
                <h3 class="font-display text-xl font-bold tracking-tight text-ink">{s.title}</h3>
                <p class="mt-2 leading-relaxed text-ink-soft">{s.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- ============ PRICING CTA BAND (3 plans, minimal) ============ -->
  <section class="border-t border-black/5 bg-surface-soft">
    <Container class="py-28 sm:py-32 lg:py-36">
      <div class="reveal mx-auto max-w-2xl text-center">
        <h2 class="font-display text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">
          Start free. Upgrade when it is landing interviews.
        </h2>
        <p class="mx-auto mt-6 max-w-md text-lg leading-relaxed text-ink-soft">
          Free includes {TIERS[0].features[0].toLowerCase()}. Paid plans unlock unlimited tailored applications across every board.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl gap-px overflow-hidden rounded-3xl border border-black/5 bg-black/5 md:grid-cols-3">
        {TIERS.map((t, i) => (
          <div
            class="reveal flex flex-col bg-surface p-8"
            style={`--reveal-delay:${i * 90}ms`}
          >
            <div class="flex items-baseline justify-between">
              <span class="font-display text-lg font-bold tracking-tight text-ink">{t.name}</span>
              {t.featured && (
                <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-[0.7rem] font-semibold text-brand-700">Popular</span>
              )}
            </div>
            <p class="mt-5 font-display text-4xl font-bold tracking-tight text-ink">
              {t.priceMonthly === 0 ? "Free" : `$${t.priceMonthly}`}
              {t.priceMonthly !== 0 && <span class="text-base font-medium text-ink-muted">/mo</span>}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{t.blurb}</p>
          </div>
        ))}
      </div>

      <div class="reveal mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href="/download" size="lg" variant="primary">Download free</Button>
        <Button href="/pricing" size="lg" variant="secondary">See all plans</Button>
      </div>
    </Container>
  </section>

  <!-- ============ FINAL DOWNLOAD CTA (airy, centered) ============ -->
  <section class="border-t border-black/5 bg-surface">
    <Container class="py-28 text-center sm:py-32 lg:py-36">
      <div class="reveal mx-auto max-w-2xl">
        <h2 class="font-display text-5xl font-bold leading-[1.02] tracking-[-0.02em] text-ink sm:text-6xl">
          Your next job is already out there.
        </h2>
        <p class="mx-auto mt-6 max-w-md text-lg leading-relaxed text-ink-soft">
          Let Scout find it and apply while you get on with your life.
        </p>
        <div class="mt-12 flex flex-col items-center gap-8 sm:flex-row sm:justify-center">
          <AppStoreBadges size="lg" class="justify-center" />
          <DownloadQR label="Scan to install" />
        </div>
      </div>
    </Container>
  </section>

  <!-- ============ MINIMAL FOOTER ============ -->
  <footer class="border-t border-black/5 bg-surface">
    <Container class="flex flex-col items-center justify-between gap-4 py-10 sm:flex-row">
      <span class="font-display text-base font-bold tracking-tight text-ink">Scout</span>
      <p class="text-sm text-ink-muted">{SITE.tagline}. Live on iOS and Android.</p>
    </Container>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(appLd)} />
</Shell>
