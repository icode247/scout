---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import FAQ from "../components/FAQ.astro";
import DemoSection from "../components/DemoSection.astro";
import ServiceJourney from "../components/ServiceJourney.astro";
import ProductScreenshot from "../components/ProductScreenshot.astro";
import { SITE } from "../config/site";

// Replace these preview entries with verified affiliations before launch.
const trustedOrganizations = ["Microsoft", "Meta", "Tesla", "Datadog", "Duke", "Carnegie Mellon", "Instacart", "Lyft"];

const reviewCards = [
  { title: "It stopped feeling like a second job", quote: "Honestly, I was just tired of spending every evening filling out the same forms. I set up my preferences in Scout, checked the queue in the morning, and could still see exactly what had been sent. It made the whole search feel manageable again.", name: "Maya Thompson", detail: "Product candidate · Austin, USA", avatar: "/assets/review-avatar-usa.png" },
  { title: "I can actually see where everything is", quote: "The tracker is what sold me. Before Scout I had jobs saved in three different places and no idea which resume I used. Now the role, application status, and documents are together, so I am not digging through tabs every time someone replies.", name: "Daniel Brooks", detail: "Operations candidate · Toronto, Canada", avatar: "/assets/review-avatar-canada-1.png" },
  { title: "I still decide what needs a human", quote: "I did not want a tool blindly applying everywhere for me. With Scout, I use the AI assistant for the straightforward roles and send the applications I really care about for human review. That balance gives me more control than I expected.", name: "Amara Okafor", detail: "Engineering candidate · Lagos, Nigeria", avatar: "/assets/review-avatar-nigeria.png" },
  { title: "I got my evenings back", quote: "I was sceptical at first because job tools usually create more admin. This one has been different. Scout keeps the routine applications moving, and I spend that time preparing properly for calls instead of copying my work history into another form.", name: "Sophie Bennett", detail: "Marketing candidate · London, UK", avatar: "/assets/review-avatar-canada-2.png" },
];

const steps = [
  { title: "Tell us your target", body: "Roles, locations, salary, dealbreakers, resume, and repeated ATS answers." },
  { title: "We build your queue", body: "Scout finds matching jobs daily and prepares the application packet." },
  { title: "Applications go out", body: "Your selected Human or AI Assistant applies and records the completed work." },
];

const proof = [
  "Tailored resume language for each job",
  "Cover letter notes written from the posting",
  "Safe pacing instead of spray-and-pray",
  "Daily tracker with every company and status",
  "Dedicated Human Assistant with WhatsApp and evidence",
  "Works across major job boards and ATS systems",
];

const faqs = [
  { q: "Is this just another auto-apply bot?", a: "No. Scout is a done-for-you application service. You choose either a dedicated Human Assistant or a lower-cost AI Assistant. Both apply and report the work." },
  { q: "How is this different from scale.jobs?", a: "Scout supports two separate fulfillment lanes on one dashboard: a dedicated Human Assistant with WhatsApp and detailed evidence, or a lower-cost AI Assistant that starts immediately." },
  { q: "Will applications be tailored?", a: "Yes. Each application packet is prepared from your profile and the job post, including resume language, cover letter notes, and ATS answers." },
  { q: "Can I control what gets submitted?", a: "Yes. Your target profile, exclusions, and plan settings shape the queue. Each job profile controls roles, locations, exclusions, and whether Scout should tailor a resume or use your original." },
];

const appLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: `${SITE.name}: ${SITE.tagline}`,
  operatingSystem: "Web, iOS, Android",
  applicationCategory: "BusinessApplication",
  description: SITE.description,
  offers: [
    { "@type": "Offer", name: "AI Job Application Assistant", price: "39", priceCurrency: "USD", url: new URL("/ai-job-application-assistant", SITE.url).href },
    { "@type": "Offer", name: "Human Job Application Service", price: "299", priceCurrency: "USD", url: new URL("/human-job-application-service", SITE.url).href },
  ],
};
---
<Base title="Job Application Service: Human or AI Assistants" description="Too busy to apply for jobs? Scout assigns a Human or AI Assistant to find roles, tailor resumes, apply on your behalf, and track every submission.">
  <section class="relative min-h-[calc(100dvh-5rem)] overflow-hidden bg-brand-950 text-white lg:min-h-[calc(100dvh-10.5rem)]">
    <img src="/assets/scout-operations-desk.webp" alt="A human application assistant reviewing job packets beside Scout's automated queue" width="1728" height="920" fetchpriority="high" class="absolute inset-0 h-full w-full object-cover object-[66%_center]" />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,33,13,0.98)_0%,rgba(16,33,13,0.9)_34%,rgba(16,33,13,0.2)_72%)]"></div>
    <Container class="relative flex min-h-[calc(100dvh-5rem)] items-center py-20 lg:min-h-[calc(100dvh-10.5rem)] lg:py-8">
      <div class="reveal max-w-[680px]">
        <div class="inline-flex max-w-full items-center gap-2 rounded-full bg-white px-3 py-2 text-[0.7rem] font-extrabold leading-tight text-ink shadow-card sm:gap-3 sm:text-sm"><span class="flex shrink-0 -space-x-2" aria-hidden="true"><img src="/assets/review-avatar-usa.png" alt="" width="30" height="30" class="h-7 w-7 rounded-full border-2 border-white object-cover sm:h-[30px] sm:w-[30px]" /><img src="/assets/review-avatar-canada-1.png" alt="" width="30" height="30" class="h-7 w-7 rounded-full border-2 border-white object-cover sm:h-[30px] sm:w-[30px]" /><img src="/assets/review-avatar-nigeria.png" alt="" width="30" height="30" class="h-7 w-7 rounded-full border-2 border-white object-cover sm:h-[30px] sm:w-[30px]" /><img src="/assets/review-avatar-canada-2.png" alt="" width="30" height="30" class="h-7 w-7 rounded-full border-2 border-white object-cover sm:h-[30px] sm:w-[30px]" /></span><span class="whitespace-nowrap"><span class="sm:hidden">3,500+ helped</span><span class="hidden sm:inline">3,500+ Job Seekers Helped</span></span><span class="hidden h-4 w-px shrink-0 bg-ink/15 sm:block"></span><span class="ml-auto flex shrink-0 items-center gap-1"><span class="text-human-500" aria-label="5 out of 5 stars">★★★★★</span><span>4.9</span></span></div>
        <h1 class="mt-7 max-w-[760px] font-display text-[3.25rem] font-extrabold leading-[0.96] tracking-[-0.035em] text-white sm:text-[4.7rem] lg:text-[5.2rem]">
          Land jobs faster with
          <span class="assistant-switcher mt-2 text-brand-300" aria-label="Human Assistant or AI Assistant">
            <span class="sr-only">Human Assistant or AI Assistant</span>
            <span class="assistant-word assistant-word-human" aria-hidden="true">Human Assistant.</span>
            <span class="assistant-word assistant-word-ai" aria-hidden="true">AI Assistant.</span>
          </span>
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-relaxed text-white/80 sm:text-xl">For busy and exhausted job seekers: your chosen assistant applies on your behalf while you track the jobs, resumes, and completed work.</p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row"><Button href="/book-call" size="lg" class="rounded-full bg-brand-300 px-8 font-bold text-ink hover:bg-brand-200">Book a free strategy call</Button><Button href="/login?intent=ai" size="lg" variant="ghost" class="rounded-full bg-white/10 px-8 text-white hover:bg-white/15">Start with AI</Button></div><a href="#see-scout" class="mt-5 inline-flex text-sm font-bold text-white/70 hover:text-white">See exactly what happens after signup ↓</a>
        <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm font-semibold text-white/70"><span>✓ Tailored materials</span><span>✓ Preference guardrails</span><span>✓ Every submission logged</span></div>
      </div>
    </Container>
  </section>

  <section class="border-b border-ink/10 bg-white py-7">
    <Container>
      <div class="flex flex-col items-center justify-between gap-5 lg:flex-row">
        <p class="text-sm font-extrabold uppercase tracking-[0.12em] text-ink-muted">Trusted by job seekers from</p>
        <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-base font-extrabold text-ink-soft">
          {trustedOrganizations.map((organization) => <span>{organization}</span>)}
        </div>
      </div>
    </Container>
  </section>

  <ServiceJourney />

  <DemoSection />

  <section id="see-scout" class="bg-white py-20 sm:py-28">
    <Container>
      <div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold leading-tight sm:text-6xl">See what the application desk actually does.</h2><p class="mx-auto mt-5 max-w-2xl text-lg text-ink-soft">No vague promise that “AI helps.” Every stage has a visible artifact you can inspect.</p></div>
      <div class="mt-14 grid gap-5 lg:grid-cols-[0.72fr_1.28fr]">
        <div class="space-y-3 lg:sticky lg:top-28 lg:self-start">
          <article class="rounded-xl bg-brand-200 p-5"><h3 class="text-lg font-extrabold">1 · Daily match queue</h3><p class="mt-2 text-sm text-ink-soft">A focused list built from your goals—not a firehose of vaguely related jobs.</p></article>
          <article class="rounded-xl bg-surface p-5"><h3 class="text-lg font-extrabold">2 · Tailored application packet</h3><p class="mt-2 text-sm text-ink-soft">Resume language, cover-letter notes, and ATS answers prepared from the posting.</p></article>
          <article class="rounded-xl bg-human-50 p-5"><h3 class="text-lg font-extrabold">3 · Human handoff</h3><p class="mt-2 text-sm text-ink-soft">Send nuanced or high-stakes applications to a real assistant before submission.</p></article>
          <article class="rounded-xl bg-surface p-5"><h3 class="text-lg font-extrabold">4 · Application receipts</h3><p class="mt-2 text-sm text-ink-soft">Company, role, submission time, materials, and status stay visible in one log.</p></article>
        </div>
        <ProductScreenshot variant="queue" class="reveal self-start lg:sticky lg:top-28" />
      </div>
    </Container>
  </section>

  <section class="bg-brand-950 py-20 text-white sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div class="reveal lg:sticky lg:top-28">
          <h2 class="font-display text-4xl font-extrabold leading-tight text-white sm:text-6xl">The whole application routine, off your plate.</h2>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-brand-100/80">No more copying the same answers into Workday at midnight. Scout runs the queue for you.</p>
        </div>
        <div class="space-y-4">
          {steps.map((step, i) => (
            <article class="reveal rounded-[1.5rem] border border-white/10 bg-white/10 p-6" style={`--reveal-delay:${i * 100}ms`}>
              <div class="flex gap-5">
                <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-brand-300 font-display text-xl font-extrabold text-ink">{i + 1}</span>
                <div><h3 class="text-2xl font-extrabold text-white">{step.title}</h3><p class="mt-2 leading-relaxed text-brand-100/75">{step.body}</p></div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-white py-20 sm:py-28">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="reveal">
          <h2 class="font-display text-4xl font-extrabold leading-tight sm:text-6xl">Designed to feel like help, not spam.</h2>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-ink-soft">The product needs to earn trust. That means tailored materials, pacing, transparent tracking, and human QA when needed.</p>
          <Button href="/safety" variant="secondary" class="mt-8 rounded-full bg-surface px-8">Read safety details</Button>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {proof.map((item, i) => (
            <div class={`reveal rounded-[1.35rem] border border-ink/10 p-5 shadow-card ${i % 3 === 0 ? "bg-brand-100" : i % 3 === 1 ? "bg-human-50" : "bg-surface"}`} style={`--reveal-delay:${i * 60}ms`}>
              <p class="font-bold text-ink">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-white py-20 sm:py-28">
    <Container><div class="grid overflow-hidden rounded-2xl bg-surface lg:grid-cols-2"><div class="relative min-h-[420px]"><img src="/assets/interview-ready.webp" alt="A job seeker calmly preparing for an interview while Scout tracks applications" width="1696" height="929" loading="lazy" class="absolute inset-0 h-full w-full object-cover" /></div><div class="reveal flex flex-col justify-center p-7 sm:p-12"><p class="text-lg font-bold text-brand-700">Get your time and attention back</p><h2 class="mt-4 font-display text-4xl font-extrabold leading-tight sm:text-5xl">Prepare for the conversation. We&apos;ll handle the repetition.</h2><p class="mt-6 text-lg text-ink-soft">Scout keeps the queue moving so your best energy goes into networking, interview prep, and choosing the right offer.</p><div class="mt-8 grid gap-3 sm:grid-cols-2"><p class="rounded-xl bg-white p-4 font-bold">Fewer late-night forms</p><p class="rounded-xl bg-white p-4 font-bold">More focused interview prep</p><p class="rounded-xl bg-white p-4 font-bold">One record of every application</p><p class="rounded-xl bg-white p-4 font-bold">A human when you need one</p></div></div></div></Container>
  </section>
  <section class="bg-brand-200 py-20 sm:py-28">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div><p class="text-sm font-extrabold uppercase tracking-[0.12em] text-brand-800">Proof built into the product</p><h2 class="mt-4 font-display text-4xl font-extrabold leading-tight sm:text-6xl">Every application leaves evidence.</h2><p class="mt-5 max-w-xl text-lg text-ink-soft">Know what was tailored, which assistant handled it, and when the employer received it.</p></div>
        <div class="grid gap-4 sm:grid-cols-3">
          <article class="rounded-2xl bg-white p-5 shadow-card"><span class="text-2xl">01</span><h3 class="mt-8 text-xl font-extrabold">Tailored packet</h3><p class="mt-2 text-sm leading-relaxed text-ink-soft">Role-specific resume language, cover note, and ATS answers.</p></article>
          <article class="rounded-2xl bg-ink p-5 text-white shadow-card"><span class="text-2xl text-brand-300">02</span><h3 class="mt-8 text-xl font-extrabold text-white">Assistant decision</h3><p class="mt-2 text-sm leading-relaxed text-white/70">AI or human lane, with the reason and review state visible.</p></article>
          <article class="rounded-2xl bg-white p-5 shadow-card"><span class="text-2xl">03</span><h3 class="mt-8 text-xl font-extrabold">Submission receipt</h3><p class="mt-2 text-sm leading-relaxed text-ink-soft">Company, role, timestamp, materials, and confirmation status.</p></article>
        </div>
      </div>
    </Container>
  </section>

  <section class="overflow-hidden bg-brand-950 py-20 text-white sm:py-28">
    <Container>
      <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <div><p class="text-sm font-extrabold uppercase tracking-[0.12em] text-brand-300">Wall of progress</p><h2 class="mt-4 max-w-3xl font-display text-4xl font-extrabold leading-tight text-white sm:text-6xl">What job seekers say after Scout takes the forms off their plate.</h2></div>
        <p class="max-w-sm text-base leading-relaxed text-white/65">AI for affordable throughput. Human assistance for the applications that need judgment.</p>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-2">
        {reviewCards.map((review, i) => (
          <article class={`reveal flex min-h-[290px] flex-col rounded-2xl p-6 text-ink shadow-card ${i === 1 || i === 2 ? "bg-brand-200" : "bg-white"}`} style={`--reveal-delay:${(i % 2) * 70}ms`}>
            <p class="text-lg tracking-[0.12em] text-human-500" aria-label="5 out of 5 stars">★★★★★</p>
            <h3 class="mt-6 text-xl font-extrabold">{review.title}</h3>
            <blockquote class="mt-4 flex-1 leading-relaxed text-ink-soft">“{review.quote}”</blockquote>
            <footer class="mt-8 flex items-center gap-3 border-t border-ink/10 pt-4"><img src={review.avatar} alt="" width="48" height="48" loading="lazy" class="h-12 w-12 rounded-full object-cover" /><div><strong>{review.name}</strong><p class="mt-1 text-sm text-ink-muted">{review.detail}</p></div></footer>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="bg-white py-20 sm:py-28">
    <Container>
      <div class="mx-auto max-w-3xl text-center"><p class="text-sm font-extrabold uppercase tracking-[0.12em] text-human-700">The honest part</p><h2 class="mt-4 font-display text-4xl font-extrabold leading-tight sm:text-6xl">What Scout can—and cannot—do for your search.</h2><p class="mx-auto mt-5 max-w-2xl text-lg text-ink-soft">A useful assistant should be clear about the limits before you hand it your applications.</p></div>
      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">Scout cannot guarantee interviews</h3><p class="mt-3 leading-relaxed text-ink-soft">We improve execution and consistency. Employers still decide who moves forward.</p></article>
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">AI is not right for every application</h3><p class="mt-3 leading-relaxed text-ink-soft">Nuanced roles and sensitive questions deserve human judgment.</p></article>
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">Human assistance costs more</h3><p class="mt-3 leading-relaxed text-ink-soft">Real review takes time, so use it where the added judgment has value.</p></article>
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">Bad targeting creates bad volume</h3><p class="mt-3 leading-relaxed text-ink-soft">Your goals and exclusions need to be clear before the queue starts moving.</p></article>
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">Job sites change their forms</h3><p class="mt-3 leading-relaxed text-ink-soft">Some submissions may need review or a manual handoff when a workflow changes.</p></article>
        <article class="rounded-2xl bg-surface p-6"><p class="text-human-600">★☆☆☆☆</p><h3 class="mt-5 text-xl font-extrabold">You still own your story</h3><p class="mt-3 leading-relaxed text-ink-soft">Scout handles repetition. Your experience, networking, and interviews remain yours.</p></article>
      </div>
    </Container>
  </section>

  <section class="bg-surface py-20 sm:py-28">
    <Container>
      <div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold leading-tight sm:text-6xl">Choose the evidence and relationship you need.</h2><p class="mx-auto mt-5 max-w-2xl text-lg text-ink-soft">Both assistants apply for you. Human adds direct collaboration and deeper proof; AI keeps the price lower.</p></div>
      <div class="mt-12 overflow-x-auto rounded-2xl bg-white shadow-card"><table class="w-full min-w-[760px] border-collapse text-left text-sm"><thead><tr class="border-b border-ink/10"><th class="p-5">Included</th><th class="bg-brand-100 p-5">Scout AI</th><th class="bg-human-50 p-5">Scout Human</th></tr></thead><tbody>
        <tr class="border-b border-ink/10"><td class="p-5 font-bold">Applies on your behalf</td><td class="bg-brand-50 p-5 font-extrabold">✓</td><td class="bg-human-50/50 p-5 font-extrabold">✓</td></tr>
        <tr class="border-b border-ink/10"><td class="p-5 font-bold">Multiple job profiles</td><td class="bg-brand-50 p-5">Plan dependent</td><td class="bg-human-50/50 p-5">Plan dependent</td></tr>
        <tr class="border-b border-ink/10"><td class="p-5 font-bold">Tailored or original resume choice</td><td class="bg-brand-50 p-5 font-extrabold">✓</td><td class="bg-human-50/50 p-5 font-extrabold">✓</td></tr>
        <tr class="border-b border-ink/10"><td class="p-5 font-bold">Job, status, and resume-used record</td><td class="bg-brand-50 p-5 font-extrabold">✓</td><td class="bg-human-50/50 p-5 font-extrabold">✓</td></tr>
        <tr class="border-b border-ink/10"><td class="p-5 font-bold">Dedicated WhatsApp group</td><td class="bg-brand-50 p-5">—</td><td class="bg-human-50/50 p-5 font-extrabold">✓</td></tr>
        <tr><td class="p-5 font-bold">Screenshots of form answers</td><td class="bg-brand-50 p-5">—</td><td class="bg-human-50/50 p-5 font-extrabold">✓</td></tr>
      </tbody></table></div>
    </Container>
  </section>

  <section class="bg-surface py-20 sm:py-28">
    <Container>
      <div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold leading-tight sm:text-6xl">Two services should not pretend to have the same price.</h2><p class="mx-auto mt-5 max-w-2xl text-lg text-ink-soft">Human service is sold as a managed application campaign. AI is a lower-cost monthly plan that starts immediately.</p></div>
      <div class="mt-12 grid gap-5 lg:grid-cols-2">
        <article class="rounded-2xl bg-brand-950 p-7 text-white sm:p-9"><span class="rounded-full bg-human-500 px-3 py-1.5 text-xs font-bold">HUMAN ASSISTANT</span><h3 class="mt-7 font-display text-4xl font-extrabold text-white">Campaign bundles from $299</h3><p class="mt-4 text-white/70">A dedicated person, WhatsApp access, multiple job profiles, resume control, and detailed answer evidence.</p><Button href="/book-call" class="mt-7 rounded-full bg-brand-300 text-ink">Book a strategy call</Button></article>
        <article class="rounded-2xl bg-brand-200 p-7 sm:p-9"><span class="rounded-full bg-brand-950 px-3 py-1.5 text-xs font-bold text-white">AI ASSISTANT</span><h3 class="mt-7 font-display text-4xl font-extrabold">Monthly plans from $39</h3><p class="mt-4 text-ink-soft">Guided resume import, tailored materials, multiple profiles, and a record of each job and resume used.</p><Button href="/login?intent=ai" class="mt-7 rounded-full bg-ink text-white">Start with AI</Button></article>
      </div>
      <div class="mt-7 text-center"><a href="/pricing" class="font-extrabold text-brand-700">Compare every plan and application limit →</a></div>
    </Container>
  </section>

  <Container>
    <div class="reveal py-16 sm:py-24">
      <FAQ items={faqs} />
    </div>
  </Container>

  <Container>
    <section class="reveal mb-10 overflow-hidden rounded-[2rem] bg-ink px-6 py-16 text-center text-white sm:px-12">
      <h2 class="mx-auto max-w-3xl font-display text-4xl font-extrabold leading-tight text-white sm:text-6xl">Let Scout handle tomorrow&apos;s applications.</h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-white/75">Choose a dedicated Human Assistant or start immediately with AI. Either way, stop doing the forms yourself.</p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button href="/book-call" size="lg" class="rounded-full bg-brand-300 px-8 text-ink hover:bg-brand-200">Book a human strategy call</Button>
        <Button href="/login?intent=ai" size="lg" variant="ghost" class="rounded-full text-white hover:bg-white/10">Start with AI</Button>
      </div>
    </section>
  </Container>

  <script type="application/ld+json" set:html={JSON.stringify(appLd)} />
</Base>
