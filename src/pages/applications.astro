---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { applicationRows, loadScoutData } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const rows = applicationRows(data);
const requested = Astro.url.searchParams.get("id");
const selected = rows.find(row=>row.id===requested) || rows[0] || null;
const statusLabel = (value:string) => value.replaceAll("_"," ").replace(/\b\w/g, letter=>letter.toUpperCase());
---
<App title="Scout applications" active="applications">
  <div class="flex flex-wrap items-end justify-between gap-4"><div><h1 class="text-3xl font-extrabold">Applications</h1><p class="mt-2 text-ink-soft">Every job, document, assistant action, and available piece of evidence.</p></div><AddJobDialog profiles={data.jobProfiles}/></div>
  {selected ? <div class="mt-7 grid min-h-[690px] overflow-hidden rounded-xl bg-white shadow-card xl:grid-cols-[380px_1fr]">
    <aside class="border-b border-ink/10 xl:border-b-0 xl:border-r"><div class="border-b border-ink/10 p-4"><input id="application-search" placeholder="Search applications" class="w-full rounded-full bg-surface px-4 py-3 text-sm"/></div><div id="application-list" class="divide-y divide-ink/10">{rows.map(row=><a href={`/applications?id=${row.id}`} data-search={`${row.job!.title} ${row.job!.company}`.toLowerCase()} class={`block w-full p-4 text-left hover:bg-surface ${row.id===selected.id?"bg-brand-50":""}`}><div class="flex justify-between gap-3"><strong class="text-sm">{row.job!.title}</strong><span class={`h-fit rounded-full px-2 py-1 text-[0.65rem] font-bold ${row.assistant_type==="human"?"bg-human-50 text-human-700":"bg-brand-100 text-brand-800"}`}>{row.assistant_type === "human" ? "Human" : "AI"}</span></div><p class="mt-1 text-xs text-ink-muted">{row.job!.company}</p><p class="mt-3 text-xs font-bold text-signal-700">{statusLabel(row.status)}</p></a>)}</div></aside>
    <section class="p-5 sm:p-7"><div class="flex flex-wrap items-start justify-between gap-4"><div><p class="text-sm text-ink-muted">{selected.job!.company} · {selected.job!.location || "Location not set"}</p><h2 class="mt-1 text-2xl font-extrabold">{selected.job!.title}</h2><p class="mt-2 text-sm">{selected.submitted_at ? `Submitted ${new Intl.DateTimeFormat("en",{dateStyle:"medium",timeStyle:"short"}).format(new Date(selected.submitted_at))}` : "Your assistant is preparing this application"}</p></div><span class="rounded-full bg-signal-50 px-3 py-1.5 text-sm font-bold text-signal-700">{statusLabel(selected.status)}</span></div>
      <div class="mt-7 flex gap-2 overflow-x-auto border-b border-ink/10" role="tablist"><button data-app-tab="overview" class="app-tab border-b-2 border-ink px-3 py-3 text-sm font-bold">Overview</button><button data-app-tab="resume" class="app-tab px-3 py-3 text-sm font-bold text-ink-muted">Resume used</button>{selected.assistant_type==="human" && <button data-app-tab="evidence" class="app-tab px-3 py-3 text-sm font-bold text-ink-muted">Answer evidence</button>}</div>
      <div data-app-panel="overview" class="app-panel"><div class="mt-7 grid gap-5 lg:grid-cols-2"><div class="rounded-xl bg-surface p-5"><p class="text-xs font-bold text-ink-muted">JOB PROFILE</p><strong class="mt-2 block">{selected.jobProfile?.name || "General profile"}</strong><p class="mt-1 text-sm text-ink-soft">{selected.jobProfile?.locations.join(" · ") || "Any location"}{selected.jobProfile?.salary_min ? ` · $${selected.jobProfile.salary_min.toLocaleString()}+` : ""}</p></div><div class="rounded-xl bg-surface p-5"><p class="text-xs font-bold text-ink-muted">ASSISTANT</p><strong class="mt-2 block">{selected.assistant_type === "human" ? data.profile.assistant_name || "Human Assistant" : "Scout AI"}</strong><p class="mt-1 text-sm text-ink-soft">{selected.assistant_type === "human" ? "Screenshots and notes can be attached" : "Job and resume activity is tracked"}</p></div></div>{selected.notes && <div class="mt-7 rounded-xl bg-human-50 p-5"><div class="flex gap-3"><span class="grid h-9 w-9 place-items-center rounded-full bg-human-500 font-bold text-white">{selected.assistant_type==="human"?"H":"AI"}</span><div><strong>Assistant note</strong><p class="mt-2 text-sm leading-relaxed text-ink-soft">{selected.notes}</p></div></div></div>}</div>
      <div data-app-panel="resume" class="app-panel hidden"><div class="mt-7 rounded-xl bg-surface p-5"><p class="text-xs font-bold text-ink-muted">RESUME USED</p>{selected.resume ? <><strong class="mt-2 block">{selected.resume.name}</strong><a href={`/api/app/resumes/${selected.resume.id}`} target="_blank" class="mt-2 inline-flex text-sm font-bold text-brand-700">Open resume →</a></> : <p class="mt-2 text-sm text-ink-muted">No resume has been assigned yet.</p>}</div></div>
      {selected.assistant_type==="human" && <div data-app-panel="evidence" class="app-panel hidden"><h3 class="mt-7 text-lg font-extrabold">Answer evidence</h3><p class="mt-1 text-sm text-ink-soft">Available for applications completed by your Human Assistant.</p><div class="mt-4 grid gap-4 sm:grid-cols-3">{selected.answer_evidence.length ? selected.answer_evidence.map((item,index)=><button class="overflow-hidden rounded-xl bg-surface text-left"><div class="h-28 bg-white p-3"><div class="h-2 w-3/4 rounded bg-ink/10"></div><div class="mt-3 h-7 rounded border border-ink/10"></div><div class="mt-3 h-2 w-1/2 rounded bg-brand-200"></div></div><div class="p-3"><strong class="text-xs">{item.label}</strong><p class="mt-1 text-[0.7rem] text-ink-muted">Evidence {index+1}</p></div></button>) : <p class="col-span-full rounded-xl bg-surface p-6 text-sm text-ink-muted">Evidence will appear after submission.</p>}</div></div>}
    </section>
  </div> : <div class="mt-7 rounded-xl bg-white p-12 text-center shadow-card"><h2 class="text-2xl font-extrabold">No applications yet</h2><p class="mx-auto mt-3 max-w-md text-ink-soft">Add a job, choose the job profile, and Scout will create the first application record when you delegate it.</p><div class="mt-6"><AddJobDialog profiles={data.jobProfiles} id="empty-add-job"/></div></div>}
  <script is:inline>
    document.getElementById("application-search")?.addEventListener("input",event=>{const query=event.target.value.toLowerCase();document.querySelectorAll("#application-list [data-search]").forEach(item=>item.classList.toggle("hidden",!item.dataset.search.includes(query)))});
    document.querySelectorAll("[data-app-tab]").forEach(tab=>tab.addEventListener("click",()=>{document.querySelectorAll("[data-app-tab]").forEach(item=>{item.classList.remove("border-b-2","border-ink");item.classList.add("text-ink-muted")});tab.classList.add("border-b-2","border-ink");tab.classList.remove("text-ink-muted");document.querySelectorAll("[data-app-panel]").forEach(panel=>panel.classList.toggle("hidden",panel.dataset.appPanel!==tab.dataset.appTab))}));
  </script>
</App>
