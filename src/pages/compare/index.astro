---
import Base from "../../layouts/Base.astro";
import Container from "../../components/Container.astro";
import MarketingCTA from "../../components/MarketingCTA.astro";
const rivals=[
 {name:"scale.jobs",model:"Human-assistant service",fit:"Users who want a person handling most applications",scout:"Scout offers a lower-cost AI plan plus its own Human Assistant service with WhatsApp, profiles, and detailed evidence."},
 {name:"LazyApply",model:"High-volume browser automation",fit:"Users optimizing primarily for volume",scout:"Scout emphasizes job profiles, resume choice, visible records, and a separate Human Assistant service."},
 {name:"JobCopilot",model:"Web auto-apply tool",fit:"Users looking for automated applications",scout:"Scout adds multiple profiles, a Chrome delegation workflow, and a dedicated Human Assistant option."},
 {name:"AIApply",model:"AI job-search toolkit",fit:"Users who want multiple AI career tools",scout:"Scout centers the done-for-you application workflow and submission receipts."},
];
const modelRows=[["Applies on your behalf","You","Yes","Yes","Yes","Yes"],["Multiple job profiles","Manual","Varies","Varies","Yes","Yes"],["Tailored or original resume choice","You","Varies","Yes","Yes","Yes"],["Job and resume-used record","Manual","Varies","Varies","Yes","Yes"],["Dedicated WhatsApp group","—","—","Varies","—","Yes"],["Answer screenshots","—","—","Varies","—","Yes"]];
---
<Base title="Compare Scout to AI and human job application services" description="Compare DIY applications, AI-only tools, human-only services, and Scout's combined AI plus human assistant model.">
  <section class="bg-brand-950 py-20 text-white sm:py-28"><Container><div class="max-w-4xl"><p class="text-lg font-bold text-brand-300">Compare service models first.</p><h1 class="mt-4 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] text-white sm:text-7xl">You should not have to choose between affordable and careful.</h1><p class="mt-6 max-w-2xl text-lg text-white/72">Scout offers two separate services on one operating system: lower-cost AI fulfillment or a dedicated Human Assistant with WhatsApp and detailed evidence.</p></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="overflow-x-auto rounded-2xl bg-surface"><table class="w-full min-w-[820px] text-left"><thead><tr class="border-b border-ink/10"><th class="p-5">Capability</th><th class="p-5">DIY</th><th class="p-5">AI-only</th><th class="p-5">Human-only</th><th class="bg-brand-100 p-5">Scout AI</th><th class="bg-human-50 p-5">Scout Human</th></tr></thead><tbody>{modelRows.map(row=><tr class="border-b border-ink/10 last:border-0">{row.map((c,i)=><td class={`p-5 ${i===0?"font-bold":""} ${i===4?"bg-brand-50 font-extrabold":i===5?"bg-human-50 font-extrabold":""}`}>{c}</td>)}</tr>)}</tbody></table></div><p class="mt-4 text-sm text-ink-muted">Typical service-model comparison. Provider capabilities and plan limits may change.</p></Container></section>
  <section class="bg-surface py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">How Scout differs from named alternatives.</h2><p class="mt-5 text-lg text-ink-soft">A positioning summary—not a claim that every competitor plan works identically.</p></div><div class="mt-12 divide-y divide-ink/10 border-y border-ink/10">{rivals.map(r=><article class="grid gap-5 py-8 md:grid-cols-[0.5fr_0.75fr_1.25fr]"><h3 class="text-2xl font-extrabold">vs {r.name}</h3><div><p class="text-sm font-bold text-ink-muted">Primary model</p><p class="mt-2 text-ink-soft">{r.model}</p><p class="mt-4 text-sm font-bold text-ink-muted">Typical fit</p><p class="mt-2 text-ink-soft">{r.fit}</p></div><p class="text-lg leading-relaxed text-ink-soft">{r.scout}</p></article>)}</div></Container></section>
  <MarketingCTA title="Choose the service model that fits your time, budget, and need for evidence." />
</Base>
