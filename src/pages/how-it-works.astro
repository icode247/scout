---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import ProcessShowcase from "../components/ProcessShowcase.astro";
import DemoSection from "../components/DemoSection.astro";
import ProductScreenshot from "../components/ProductScreenshot.astro";
import MarketingCTA from "../components/MarketingCTA.astro";
---
<Base title="How Scout works" description="See how Scout matches jobs, prepares tailored applications, routes work to AI or a human assistant, and records every submission.">
  <section class="bg-brand-950 py-20 text-white sm:py-28">
    <Container><div class="grid items-center gap-12 lg:grid-cols-[0.82fr_1.18fr]"><div><p class="text-lg font-bold text-brand-300">One profile. A daily application desk.</p><h1 class="mt-4 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] text-white sm:text-7xl">From target role to submitted application.</h1><p class="mt-6 max-w-xl text-lg leading-relaxed text-white/72">Choose your assistant lane, import your resume, and build one or more job profiles. Scout then runs the queue and records what happened.</p><div class="mt-8 flex flex-wrap gap-3"><Button href="/book-call" size="lg" class="rounded-full bg-brand-300 text-ink">Book a human strategy call</Button><Button href="/login?intent=ai" size="lg" variant="ghost" class="rounded-full bg-white/10 text-white">Start with AI</Button></div></div><ProductScreenshot variant="queue" /></div></Container>
  </section>
  <ProcessShowcase />
  <div id="tour"><DemoSection /></div>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">The handoffs are the product.</h2><p class="mt-5 text-lg text-ink-soft">Human and AI are separate service lanes. Both apply for you; Human adds direct WhatsApp collaboration and detailed form evidence.</p></div><div class="mt-14 space-y-16">
    <div class="grid items-center gap-10 lg:grid-cols-2"><div><p class="text-lg font-bold text-brand-700">Match and prepare</p><h3 class="mt-3 font-display text-4xl font-extrabold">The queue starts with your boundaries.</h3><p class="mt-5 text-lg leading-relaxed text-ink-soft">Roles, locations, salary, exclusions, and experience shape every match. Scout then prepares the resume language and ATS answers from the posting.</p></div><ProductScreenshot variant="documents" /></div>
    <div class="grid items-center gap-10 lg:grid-cols-2"><ProductScreenshot variant="human" class="lg:order-1" /><div class="lg:order-2"><p class="text-lg font-bold text-human-700">Escalate when needed</p><h3 class="mt-3 font-display text-4xl font-extrabold">Nuance goes to a person, not a guess.</h3><p class="mt-5 text-lg leading-relaxed text-ink-soft">Your assigned assistant learns your preferences, applies for you, answers questions in WhatsApp, and saves screenshots of important form answers.</p></div></div>
    <div class="grid items-center gap-10 lg:grid-cols-2"><div><p class="text-lg font-bold text-signal-700">Submit and record</p><h3 class="mt-3 font-display text-4xl font-extrabold">Every completed application leaves a receipt.</h3><p class="mt-5 text-lg leading-relaxed text-ink-soft">See the company, role, job profile, resume used, submission time, assistant lane, and available evidence in one application log.</p></div><ProductScreenshot variant="tracker" /></div>
  </div></Container></section>
  <MarketingCTA />
</Base>
