---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { loadScoutData } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const resumesForProfile = (profile: (typeof data.jobProfiles)[number]) => data.resumes.filter((resume) => (profile.resume_ids || []).includes(resume.id));
const extractionLabel = (status?: string) => status === "complete" ? "Analyzed" : status === "processing" ? "Analyzing" : status === "failed" ? "Needs review" : "Pending";
---
<App title="Scout job profiles" active="profiles">
  <div class="flex flex-wrap items-end justify-between gap-4"><div><h1 class="text-3xl font-extrabold">Job profiles</h1><p class="mt-2 text-ink-soft">Keep role searches, locations, rules, and resumes from bleeding into each other.</p></div><button id="new-profile" class="rounded-full bg-ink px-5 py-3 text-sm font-extrabold text-white">+ New job profile</button></div>
  <div class="mt-7 grid gap-5 lg:grid-cols-3">{data.jobProfiles.map((profile,index)=><article class={`rounded-xl p-6 shadow-card ${index===0?"bg-brand-200":"bg-white"}`}><div class="flex items-start justify-between gap-3"><span class={`rounded-full px-2.5 py-1 text-xs font-bold ${profile.assistant_type==="human"?"bg-human-50 text-human-700":"bg-brand-100 text-brand-800"}`}>{profile.assistant_type === "human" ? "Human Assistant" : "AI Assistant"}</span>{!profile.active && <span class="rounded-full bg-surface px-2.5 py-1 text-xs font-bold text-ink-muted">Paused</span>}<div class="flex gap-3"><button data-edit-profile={profile.id} class="text-xs font-bold text-brand-800">Edit</button><button data-delete-profile={profile.id} class="text-xs font-bold text-ink-muted hover:text-red-700" aria-label={`Delete ${profile.name}`}>Delete</button></div></div><h2 class="mt-7 break-words text-2xl font-extrabold">{profile.name}</h2><p class="mt-2 text-sm text-ink-soft">{profile.locations.join(" · ") || "Any location"}</p><p class="mt-1 text-sm text-ink-soft">{profile.target_roles.length} target {profile.target_roles.length===1?"title":"titles"} · {profile.resume_behavior === "tailor" ? "Tailored resume" : "Original resume"}</p>{profile.salary_min && <p class="mt-1 text-sm text-ink-soft">From {new Intl.NumberFormat("en-US",{style:"currency",currency:"USD",maximumFractionDigits:0}).format(profile.salary_min)}</p>}<div class="mt-5 border-t border-ink/10 pt-4"><p class="text-xs font-bold text-ink-muted">PROFILE RESUMES</p>{resumesForProfile(profile).length ? <div class="mt-2 space-y-1">{resumesForProfile(profile).map((resume,index)=><a href={`/api/app/resumes/${resume.id}`} target="_blank" class="flex items-center gap-2 text-xs font-bold text-brand-800"><span class="grid h-5 w-5 shrink-0 place-items-center rounded bg-brand-100 text-[0.55rem]">CV</span><span class="min-w-0 flex-1 truncate">{resume.name}</span>{index===0&&<span class="text-[0.6rem] text-ink-muted">PRIMARY</span>}</a>)}</div> : <p class="mt-2 text-xs text-red-700">No resume attached. Edit this profile before delegating jobs.</p>}</div><div class="mt-7">{data.profile.assistant_type === "ai" ? <a href={`/agent?profile=${profile.id}`} class="inline-block rounded-full bg-ink px-5 py-3 text-sm font-extrabold text-white">Configure Scout AI</a> : profile.active ? <AddJobDialog profiles={[profile]} triggerLabel="Add a job" id={`add-job-${profile.id}`}/> : <p class="text-xs font-bold text-ink-muted">Resume this profile before adding jobs.</p>}</div></article>)}</div>
  {!data.jobProfiles.length && <div class="mt-7 rounded-xl bg-white p-10 text-center shadow-card"><strong>Create your first job profile</strong><p class="mt-2 text-sm text-ink-muted">Profiles tell Scout which role, location, assistant, and resume rules to use.</p></div>}

  <section id="resumes" class="mt-10 rounded-xl bg-white p-6 shadow-card"><div class="flex flex-wrap items-center justify-between gap-4"><div><h2 class="text-xl font-extrabold">Resume library</h2><p class="mt-1 text-sm text-ink-muted">Upload, rename, inspect, and safely remove resume versions.</p></div><label id="resume-upload-label" class="cursor-pointer rounded-full bg-surface px-4 py-2.5 text-sm font-bold"><input id="resume-upload" type="file" name="resume" accept=".pdf,.doc,.docx" class="sr-only"/>Upload resume</label></div><div class="mt-6 divide-y divide-ink/10">{data.resumes.length ? data.resumes.map(resume=><form data-resume-row={resume.id} class="flex flex-wrap items-center justify-between gap-4 py-4"><div class="min-w-0 flex-1"><label class="sr-only" for={`resume-name-${resume.id}`}>Resume name</label><input id={`resume-name-${resume.id}`} name="name" value={resume.name} maxlength="180" class="w-full max-w-xl rounded-lg border border-transparent bg-transparent px-2 py-1 text-sm font-bold hover:border-ink/15 focus:border-ink/20 focus:outline-none"/><p class="mt-1 px-2 text-xs text-ink-muted">{new Intl.DateTimeFormat("en",{dateStyle:"medium"}).format(new Date(resume.created_at))} · {extractionLabel((resume as any).extraction_status)}</p></div><div class="flex flex-wrap items-center gap-2"><a href={`/api/app/resumes/${resume.id}`} target="_blank" class="rounded-full bg-brand-100 px-3 py-2 text-xs font-bold">Open</a><button type="submit" class="rounded-full bg-surface px-3 py-2 text-xs font-bold">Save name</button><button type="button" data-delete-resume={resume.id} class="rounded-full px-3 py-2 text-xs font-bold text-red-700">Delete</button></div><p data-resume-error class="hidden w-full text-xs font-bold text-red-700" role="alert"></p></form>) : <p class="py-8 text-center text-sm text-ink-muted">No resumes uploaded yet.</p>}</div></section>

  <dialog id="profile-dialog" class="w-[min(92vw,42rem)] rounded-2xl p-0 shadow-lift backdrop:bg-ink/55"><form id="profile-form" class="p-7"><input type="hidden" name="id"/><div class="flex justify-between gap-4"><div><p class="text-xs font-bold text-brand-700">SEARCH RULES</p><h2 id="profile-dialog-title" class="mt-2 text-2xl font-extrabold">New job profile</h2></div><button type="button" data-close class="grid h-10 w-10 place-items-center rounded-full bg-surface" aria-label="Close profile editor">×</button></div><div class="mt-6 grid gap-4 sm:grid-cols-2"><label class="text-sm font-bold sm:col-span-2">Profile name<input required maxlength="120" name="name" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Product leadership"/></label><label class="text-sm font-bold">Assistant<input type="hidden" name="assistant_type" value={data.profile.assistant_type}/><span class="mt-2 block rounded-xl bg-surface px-4 py-3 font-normal">{data.profile.assistant_type === "human" ? "Human Assistant" : "Scout AI Agent"}</span></label><label class="text-sm font-bold">Profile status<select name="active" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 font-normal"><option value="true">Active</option><option value="false">Paused</option></select></label><label class="text-sm font-bold">Minimum salary<input name="salary_min" type="number" min="0" max="10000000" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="120000"/></label><label class="text-sm font-bold sm:col-span-2">Target roles<input required name="target_roles" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Product Manager, Product Lead"/></label><label class="text-sm font-bold sm:col-span-2">Locations<input name="locations" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Remote, New York"/></label><label class="text-sm font-bold sm:col-span-2">Resume behavior<select name="resume_behavior" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 font-normal"><option value="tailor">Tailor for every job</option><option value="original">Use original resume</option></select></label>
      <fieldset class="sm:col-span-2"><legend class="text-sm font-bold">Use resumes</legend><p class="mt-1 text-xs text-ink-muted">The first selected resume becomes primary.</p><div id="existing-resume-options" class="mt-3 grid gap-2 sm:grid-cols-2">{data.resumes.map(resume=><label class="flex min-w-0 items-center gap-2 rounded-lg bg-surface px-3 py-3 text-sm"><input type="checkbox" name="resume_ids" value={resume.id}/><span class="truncate">{resume.name}</span></label>)}</div>{!data.resumes.length && <p class="mt-3 rounded-lg bg-surface p-3 text-sm text-ink-muted">Upload at least one resume below.</p>}</fieldset>
      <label class="text-sm font-bold sm:col-span-2">Upload additional resumes <span class="font-normal text-ink-muted">(optional)</span><input id="profile-resumes" name="resumes" type="file" multiple accept=".pdf,.doc,.docx" class="mt-2 block w-full rounded-xl border border-dashed border-ink/20 bg-surface px-4 py-5 font-normal file:mr-3 file:rounded-full file:border-0 file:bg-ink file:px-4 file:py-2 file:text-xs file:font-bold file:text-white"/><span id="profile-resume-summary" class="mt-2 block text-xs font-normal text-ink-muted">PDF, DOC, or DOCX · Up to 10 MB each</span></label>
    </div><p data-error class="mt-4 hidden rounded-lg bg-red-50 p-3 text-sm font-bold text-red-700" role="alert"></p><div class="mt-6 flex justify-end gap-3"><button type="button" data-close class="rounded-full px-5 py-3 font-bold">Cancel</button><button id="profile-submit" type="submit" class="rounded-full bg-brand-500 px-6 py-3 font-extrabold">Create profile</button></div></form></dialog>
  <script define:vars={{ profiles: data.jobProfiles }}>
    const dialog=document.getElementById("profile-dialog"),form=document.getElementById("profile-form"),profileResumes=document.getElementById("profile-resumes"),resumeSummary=document.getElementById("profile-resume-summary"),title=document.getElementById("profile-dialog-title"),submit=document.getElementById("profile-submit"),error=form?.querySelector("[data-error]");
    const resumeChecks=()=>[...form.querySelectorAll("[name=resume_ids]")];
    function openProfile(profile){
      form.reset();error.classList.add("hidden");form.elements.id.value=profile?.id||"";
      form.elements.name.value=profile?.name||"";form.elements.assistant_type.value=profile?.assistant_type||"ai";form.elements.active.value=profile?.active===false?"false":"true";form.elements.salary_min.value=profile?.salary_min||"";form.elements.target_roles.value=(profile?.target_roles||[]).join(", ");form.elements.locations.value=(profile?.locations||[]).join(", ");form.elements.resume_behavior.value=profile?.resume_behavior||"tailor";
      const ids=new Set(profile?.resume_ids||[]);resumeChecks().forEach((input,index)=>input.checked=profile?ids.has(input.value):index===0);
      title.textContent=profile?"Edit job profile":"New job profile";submit.textContent=profile?"Save changes":"Create profile";resumeSummary.textContent="PDF, DOC, or DOCX · Up to 10 MB each";dialog.showModal();
    }
    document.getElementById("new-profile")?.addEventListener("click",()=>openProfile(null));
    document.querySelectorAll("[data-edit-profile]").forEach(button=>button.addEventListener("click",()=>openProfile(profiles.find(profile=>profile.id===button.dataset.editProfile))));
    dialog?.querySelectorAll("[data-close]").forEach(button=>button.addEventListener("click",()=>dialog.close()));
    dialog?.addEventListener("click",event=>{if(event.target===dialog)dialog.close()});
    profileResumes?.addEventListener("change",()=>{const count=profileResumes.files.length;resumeSummary.textContent=count?count+" resume"+(count===1?"":"s")+" selected: "+[...profileResumes.files].map(file=>file.name).join(", "):"PDF, DOC, or DOCX · Up to 10 MB each"});
    form?.addEventListener("submit",async event=>{event.preventDefault();const editing=Boolean(form.elements.id.value);submit.disabled=true;submit.textContent=editing?"Saving…":"Uploading and creating…";error.classList.add("hidden");try{const response=await fetch("/api/app/profiles",{method:editing?"PATCH":"POST",body:new FormData(form)});const data=await response.json();if(!response.ok)throw new Error(data.error||"Could not save profile");location.reload()}catch(reason){error.textContent=reason instanceof Error?reason.message:"Could not save profile";error.classList.remove("hidden");submit.disabled=false;submit.textContent=editing?"Save changes":"Create profile"}});
    document.querySelectorAll("[data-delete-profile]").forEach(button=>button.addEventListener("click",async()=>{if(!confirm("Delete this job profile? Existing jobs and application records will remain."))return;button.disabled=true;const response=await fetch("/api/app/profiles?id="+encodeURIComponent(button.dataset.deleteProfile),{method:"DELETE"});const data=await response.json();if(response.ok)location.reload();else{button.disabled=false;window.scoutToast?.(data.error||"Could not delete profile",true)}}));
    document.getElementById("resume-upload")?.addEventListener("change",async event=>{const file=event.target.files[0];if(!file)return;const body=new FormData();body.append("resume",file);const label=document.getElementById("resume-upload-label");label.classList.add("opacity-60","pointer-events-none");window.scoutToast?.("Uploading and analyzing resume…");try{const response=await fetch("/api/app/resumes",{method:"POST",body});const data=await response.json();if(!response.ok)throw new Error(data.error||"Upload failed");window.scoutToast?.(data.warning?"Resume uploaded; analysis needs review":"Resume uploaded and analyzed");location.reload()}catch(reason){label.classList.remove("opacity-60","pointer-events-none");window.scoutToast?.(reason instanceof Error?reason.message:"Upload failed",true)}});
    document.querySelectorAll("[data-resume-row]").forEach(row=>row.addEventListener("submit",async event=>{event.preventDefault();const button=row.querySelector("[type=submit]"),error=row.querySelector("[data-resume-error]"),name=row.elements.name.value.trim();button.disabled=true;const response=await fetch("/api/app/resumes",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify({id:row.dataset.resumeRow,name})});const data=await response.json();button.disabled=false;if(response.ok)window.scoutToast?.("Resume name saved");else{error.textContent=data.error||"Could not rename resume";error.classList.remove("hidden")}}));
    document.querySelectorAll("[data-delete-resume]").forEach(button=>button.addEventListener("click",async()=>{if(!confirm("Delete this resume? This cannot be undone."))return;button.disabled=true;const row=button.closest("[data-resume-row]"),error=row.querySelector("[data-resume-error]");const response=await fetch("/api/app/resumes?id="+encodeURIComponent(button.dataset.deleteResume),{method:"DELETE"});const data=await response.json();if(response.ok)location.reload();else{button.disabled=false;error.textContent=data.error||"Could not delete resume";error.classList.remove("hidden")}}));
  </script>
</App>
