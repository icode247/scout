---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { loadScoutData } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const resumesForProfile = (profile: (typeof data.jobProfiles)[number]) => data.resumes.filter((resume) => (profile.resume_ids || []).includes(resume.id));
---
<App title="Scout job profiles" active="profiles">
  <div class="flex flex-wrap items-end justify-between gap-4"><div><h1 class="text-3xl font-extrabold">Job profiles</h1><p class="mt-2 text-ink-soft">Keep different role searches, locations, rules, and resumes from bleeding into each other.</p></div><button id="new-profile" class="rounded-full bg-ink px-5 py-3 text-sm font-extrabold text-white">+ New job profile</button></div>
  <div class="mt-7 grid gap-5 lg:grid-cols-3">{data.jobProfiles.map((profile,index)=><article class={`rounded-xl p-6 shadow-card ${index===0?"bg-brand-200":"bg-white"}`}><div class="flex items-start justify-between"><span class={`rounded-full px-2.5 py-1 text-xs font-bold ${profile.assistant_type==="human"?"bg-human-50 text-human-700":"bg-brand-100 text-brand-800"}`}>{profile.assistant_type === "human" ? "Human Assistant" : "AI Assistant"}</span><button data-delete-profile={profile.id} class="text-xs font-bold text-ink-muted hover:text-red-700" aria-label={`Delete ${profile.name}`}>Delete</button></div><h2 class="mt-7 text-2xl font-extrabold">{profile.name}</h2><p class="mt-2 text-sm text-ink-soft">{profile.locations.join(" · ") || "Any location"}</p><p class="mt-1 text-sm text-ink-soft">{profile.target_roles.length} target {profile.target_roles.length===1?"title":"titles"} · {profile.resume_behavior === "tailor" ? "Tailored resume" : "Original resume"}</p>{profile.salary_min && <p class="mt-1 text-sm text-ink-soft">From {new Intl.NumberFormat("en-US",{style:"currency",currency:"USD",maximumFractionDigits:0}).format(profile.salary_min)}</p>}<div class="mt-5 border-t border-ink/10 pt-4"><p class="text-xs font-bold text-ink-muted">PROFILE RESUMES</p>{resumesForProfile(profile).length ? <div class="mt-2 space-y-1">{resumesForProfile(profile).map((resume,index)=><a href={`/api/app/resumes/${resume.id}`} target="_blank" class="flex items-center gap-2 truncate text-xs font-bold text-brand-800"><span class="grid h-5 w-5 shrink-0 place-items-center rounded bg-brand-100 text-[0.55rem]">PDF</span><span class="truncate">{resume.name}</span>{index===0&&<span class="ml-auto text-[0.6rem] text-ink-muted">PRIMARY</span>}</a>)}</div> : <p class="mt-2 text-xs text-ink-muted">No resume attached</p>}</div><div class="mt-7"><AddJobDialog profiles={[profile]} triggerLabel="Add a job" id={`add-job-${profile.id}`}/></div></article>)}</div>
  {!data.jobProfiles.length && <div class="mt-7 rounded-xl bg-white p-10 text-center shadow-card"><strong>Create your first job profile</strong><p class="mt-2 text-sm text-ink-muted">Profiles tell Scout which role, location, assistant, and resume rules to use.</p></div>}
  <section id="resumes" class="mt-10 rounded-xl bg-white p-6 shadow-card"><div class="flex flex-wrap items-center justify-between gap-4"><div><h2 class="text-xl font-extrabold">Resume library</h2><p class="mt-1 text-sm text-ink-muted">Original resumes and job-specific versions created by Scout.</p></div><label class="cursor-pointer rounded-full bg-surface px-4 py-2.5 text-sm font-bold"><input id="resume-upload" type="file" name="resume" accept=".pdf,.doc,.docx" class="sr-only"/>Upload resume</label></div><div class="mt-6 divide-y divide-ink/10">{data.resumes.length ? data.resumes.map(resume=><div class="flex flex-wrap items-center justify-between gap-4 py-4"><div><strong class="text-sm">{resume.name}</strong><p class="mt-1 text-xs text-ink-muted">{new Intl.DateTimeFormat("en",{dateStyle:"medium"}).format(new Date(resume.created_at))}</p></div><a href={`/api/app/resumes/${resume.id}`} target="_blank" class="rounded-full bg-brand-100 px-3 py-1 text-xs font-bold">{resume.kind === "original" ? "Original" : "Tailored"}</a></div>) : <p class="py-8 text-center text-sm text-ink-muted">No resumes uploaded yet.</p>}</div></section>

  <dialog id="profile-dialog" class="w-[min(92vw,38rem)] rounded-2xl p-0 shadow-lift backdrop:bg-ink/55"><form id="profile-form" class="p-7"><div class="flex justify-between"><div><p class="text-xs font-bold text-brand-700">SEARCH RULES</p><h2 class="mt-2 text-2xl font-extrabold">New job profile</h2></div><button type="button" data-close class="grid h-9 w-9 place-items-center rounded-full bg-surface">×</button></div><div class="mt-6 grid gap-4 sm:grid-cols-2"><label class="text-sm font-bold sm:col-span-2">Profile name<input required name="name" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Product leadership"/></label><label class="text-sm font-bold">Assistant<select name="assistant_type" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 font-normal"><option value="human">Human Assistant</option><option value="ai">AI Assistant</option></select></label><label class="text-sm font-bold">Minimum salary<input name="salary_min" type="number" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="120000"/></label><label class="text-sm font-bold sm:col-span-2">Target roles<input required name="target_roles" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Product Manager, Product Lead"/></label><label class="text-sm font-bold sm:col-span-2">Locations<input name="locations" class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal" placeholder="Remote, New York"/></label><label class="text-sm font-bold sm:col-span-2">Resume behavior<select name="resume_behavior" class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 font-normal"><option value="tailor">Tailor for every job</option><option value="original">Use original resume</option></select></label><label class="text-sm font-bold sm:col-span-2">Resume files <span class="font-normal text-ink-muted">(one or more)</span><input id="profile-resumes" name="resumes" type="file" multiple accept=".pdf,.doc,.docx" class="mt-2 block w-full rounded-xl border border-dashed border-ink/20 bg-surface px-4 py-5 font-normal file:mr-3 file:rounded-full file:border-0 file:bg-ink file:px-4 file:py-2 file:text-xs file:font-bold file:text-white"/><span id="profile-resume-summary" class="mt-2 block text-xs font-normal text-ink-muted">PDF, DOC, or DOCX · Up to 10 MB each</span></label></div><p data-error class="mt-4 hidden text-sm font-bold text-red-700"></p><div class="mt-6 flex justify-end gap-3"><button type="button" data-close class="rounded-full px-5 py-3 font-bold">Cancel</button><button type="submit" class="rounded-full bg-brand-500 px-6 py-3 font-extrabold">Create profile</button></div></form></dialog>
  <script is:inline>
    const dialog=document.getElementById("profile-dialog"),form=document.getElementById("profile-form"),profileResumes=document.getElementById("profile-resumes"),resumeSummary=document.getElementById("profile-resume-summary");
    document.getElementById("new-profile")?.addEventListener("click",()=>dialog.showModal());
    dialog?.querySelectorAll("[data-close]").forEach(button=>button.addEventListener("click",()=>dialog.close()));
    profileResumes?.addEventListener("change",()=>{const count=profileResumes.files.length;resumeSummary.textContent=count ? count+" resume"+(count===1?"":"s")+" selected: "+[...profileResumes.files].map(file=>file.name).join(", ") : "PDF, DOC, or DOCX · Up to 10 MB each"});
    form?.addEventListener("submit",async event=>{event.preventDefault();const submit=form.querySelector("[type=submit]"),error=form.querySelector("[data-error]");submit.disabled=true;submit.textContent="Uploading and creating…";const response=await fetch("/api/app/profiles",{method:"POST",body:new FormData(form)});const data=await response.json();if(response.ok)location.reload();else{error.textContent=data.error;error.classList.remove("hidden");submit.disabled=false;submit.textContent="Create profile"}});
    document.querySelectorAll("[data-delete-profile]").forEach(button=>button.addEventListener("click",async()=>{if(!confirm("Delete this job profile? Jobs already added will remain."))return;const response=await fetch("/api/app/profiles?id="+encodeURIComponent(button.dataset.deleteProfile),{method:"DELETE"});if(response.ok)location.reload();else window.scoutToast?.("Could not delete profile",true)}));
    document.getElementById("resume-upload")?.addEventListener("change",async event=>{const file=event.target.files[0];if(!file)return;const body=new FormData();body.append("resume",file);window.scoutToast?.("Uploading resume…");const response=await fetch("/api/app/resumes",{method:"POST",body});const data=await response.json();if(response.ok)location.reload();else window.scoutToast?.(data.error||"Upload failed",true)});
  </script>
</App>
