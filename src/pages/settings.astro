---
import App from "../layouts/App.astro";
export const prerender = false;
const user = Astro.locals.user!;
const profile = Astro.locals.scoutProfile;
const name = profile?.full_name || user.user_metadata?.full_name || "";
---
<App title="Account settings" active="settings">
  <div class="max-w-3xl"><p class="text-sm font-extrabold text-signal-700">ACCOUNT</p><h1 class="mt-2 text-3xl font-extrabold">Settings</h1><p class="mt-2 text-ink-soft">Manage the identity attached to your Scout workspace.</p></div>
  <section class="mt-8 max-w-3xl rounded-xl bg-white p-6 shadow-card sm:p-8">
    <h2 class="text-xl font-extrabold">Personal details</h2>
    <form id="settings-form" class="mt-6 grid gap-5">
      <label class="text-sm font-bold">Full name<input name="full_name" value={name} minlength="2" maxlength="100" required class="mt-2 w-full rounded-xl border border-ink/15 px-4 py-3 font-normal"/></label>
      <label class="text-sm font-bold">Email<input value={user.email} readonly class="mt-2 w-full rounded-xl border border-ink/10 bg-surface px-4 py-3 font-normal text-ink-muted"/><span class="mt-2 block text-xs font-normal text-ink-muted">Your sign-in email is managed by your authentication provider.</span></label>
      <div><button class="rounded-full bg-ink px-5 py-3 text-sm font-extrabold text-white">Save changes</button><p id="settings-error" class="mt-3 hidden text-sm font-bold text-red-700" role="alert"></p></div>
    </form>
  </section>
  <section class="mt-6 max-w-3xl rounded-xl border border-red-200 bg-white p-6 sm:p-8"><h2 class="text-xl font-extrabold">Account and data</h2><p class="mt-2 text-sm leading-relaxed text-ink-soft">Deleting your account permanently removes your profiles, resumes, jobs, applications, and stored files.</p><a href="/delete-account" class="mt-5 inline-flex text-sm font-extrabold text-red-700">Delete my Scout account →</a></section>
  <script is:inline>
    document.getElementById("settings-form")?.addEventListener("submit",async event=>{event.preventDefault();const form=event.currentTarget,button=form.querySelector("button"),error=form.querySelector("#settings-error");button.disabled=true;button.textContent="Saving…";error.classList.add("hidden");try{const response=await fetch("/api/app/settings",{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify(Object.fromEntries(new FormData(form).entries()))});const data=await response.json();if(!response.ok)throw new Error(data.error||"Could not save settings");window.scoutToast?.("Settings saved");button.textContent="Saved";setTimeout(()=>{button.disabled=false;button.textContent="Save changes"},1200)}catch(reason){error.textContent=reason instanceof Error?reason.message:"Could not save settings";error.classList.remove("hidden");button.disabled=false;button.textContent="Save changes"}});
  </script>
</App>
