---
import Auth from "../layouts/Auth.astro";
export const prerender = false;
const initialAssistant = Astro.url.searchParams.get("intent") === "ai" ? "ai" : "human";
---
<Auth title="Set up your Scout application desk" description="Choose an assistant, import your resume, and prepare your first Scout job profile." noindex={true}>
<section class="min-h-[calc(100dvh-5rem)] bg-[#f7faf5] py-8 sm:py-12">
  <div class="mx-auto max-w-5xl px-5">
    <div class="flex items-center justify-between gap-4"><a href="/" class="font-display text-xl font-extrabold">Scout</a><span id="step-label" class="text-sm font-bold text-ink-muted">Step 1 of 4</span></div>
    <div class="mt-5 h-2 overflow-hidden rounded-full bg-white"><div id="progress" class="h-full w-1/4 rounded-full bg-brand-500 transition-[width] duration-200"></div></div>
    <form id="onboarding-form" action="/api/app/onboarding" method="post" enctype="multipart/form-data" class="mt-8"><input type="hidden" name="resume_id" value="">
      <section data-step="1" class="step-panel"><div class="mx-auto max-w-3xl text-center"><h1 class="font-display text-4xl font-extrabold sm:text-6xl">Who should handle your applications?</h1><p class="mx-auto mt-5 max-w-xl text-lg text-ink-soft">You can change plans later. This choice sets the setup and evidence you will see.</p></div><div class="mt-10 grid gap-5 md:grid-cols-2"><label class="assistant-choice cursor-pointer rounded-2xl bg-white p-7 shadow-card ring-brand-500 has-[:checked]:ring-2"><input class="sr-only" type="radio" name="assistant" value="human" checked={initialAssistant === "human"}><span class="rounded-full bg-human-500 px-3 py-1.5 text-xs font-extrabold text-white">HUMAN</span><h2 class="mt-6 text-3xl font-extrabold">Human Assistant</h2><p class="mt-3 leading-relaxed text-ink-soft">A person applies, chats with you on WhatsApp, and saves detailed application evidence.</p><ul class="mt-6 space-y-2 text-sm font-bold"><li>✓ Dedicated assistant</li><li>✓ WhatsApp group</li><li>✓ Answer screenshots</li></ul></label><label class="assistant-choice cursor-pointer rounded-2xl bg-brand-100 p-7 ring-brand-500 has-[:checked]:ring-2"><input class="sr-only" type="radio" name="assistant" value="ai" checked={initialAssistant === "ai"}><span class="rounded-full bg-brand-950 px-3 py-1.5 text-xs font-extrabold text-white">LOWER COST</span><h2 class="mt-6 text-3xl font-extrabold">AI Assistant</h2><p class="mt-3 leading-relaxed text-ink-soft">An AI agent runs the routine queue and records every job and resume used.</p><ul class="mt-6 space-y-2 text-sm font-bold"><li>✓ Start immediately</li><li>✓ Tailored resumes</li><li>✓ Application tracking</li></ul></label></div></section>
      <section data-step="2" class="step-panel hidden"><div class="mx-auto max-w-2xl text-center"><h1 class="font-display text-4xl font-extrabold sm:text-6xl">Give Scout the resume you use today.</h1><p class="mt-5 text-lg text-ink-soft">We will show every field we extract before building your first profile.</p><label class="mt-10 block cursor-pointer rounded-2xl border-2 border-dashed border-brand-500 bg-white p-12"><input id="resume-file" name="resume" type="file" class="sr-only" accept=".pdf,.doc,.docx"><span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-brand-100 text-2xl">↑</span><strong id="file-label" class="mt-5 block text-lg">Drop your resume or choose a file</strong><span class="mt-2 block text-sm text-ink-muted">PDF or DOCX · Up to 10 MB</span></label><p class="mt-4 text-sm text-ink-muted">Encrypted during upload. Your data is never sold.</p></div></section>
      <section data-step="3" class="step-panel hidden"><div class="mx-auto max-w-4xl"><div class="text-center"><p id="extraction-kicker" class="font-bold text-signal-700">Reading your resume</p><h1 class="font-display text-4xl font-extrabold sm:text-6xl">Building your application profile.</h1><p id="extraction-message" class="mt-4 text-lg text-ink-soft">Scout is extracting facts you can review. This may take up to a minute.</p></div><div class="mt-10 grid gap-5 rounded-2xl bg-white p-6 shadow-card lg:grid-cols-[0.85fr_1.15fr]"><div id="extraction-checks" class="space-y-3"><div class="rounded-xl bg-brand-100 p-4"><strong>Reading contact and work history…</strong><p class="mt-1 text-sm text-ink-soft">Nothing is saved as a profile until you review it.</p></div><div class="rounded-xl bg-surface p-4 text-ink-muted"><strong>Manual entry is always available</strong><p class="mt-1 text-sm">If analysis fails, continue and enter your targets yourself.</p></div></div><div class="rounded-xl bg-brand-950 p-6 text-white"><p class="text-xs font-bold text-brand-300">RESUME EXTRACTION</p><h2 id="extracted-headline" class="mt-4 text-2xl font-extrabold text-white">Analyzing your document…</h2><p id="extracted-summary" class="mt-2 text-sm text-white/60">Checking roles, achievements, education, and skills.</p><div class="mt-7 h-2 rounded-full bg-white/10"><div id="extraction-progress" class="h-full w-1/4 rounded-full bg-brand-300 transition-all"></div></div><div id="extracted-skills" class="mt-7 flex flex-wrap gap-2 text-xs font-bold"></div></div></div></div></section><section data-step="4" class="step-panel hidden"><div class="mx-auto max-w-4xl"><div class="text-center"><p class="font-bold text-signal-700">Your desk is ready</p><h1 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">Review your first job profile.</h1></div><div class="mt-10 rounded-2xl bg-white p-7 shadow-card"><div class="flex flex-wrap items-start justify-between gap-4"><div><h2 class="text-2xl font-extrabold">Product roles</h2><p class="mt-1 text-ink-muted">Created from your resume</p></div><span class="rounded-full bg-signal-50 px-3 py-1.5 text-xs font-bold text-signal-700">Ready</span></div><div class="mt-7 grid gap-4 sm:grid-cols-2"><label class="text-sm font-bold">Target roles<input name="target_roles" value="" placeholder="Product Manager, Operations Lead" class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"></label><label class="text-sm font-bold">Locations<input name="locations" value="" placeholder="Remote, Lagos, London" class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"></label><label class="text-sm font-bold">Resume behavior<select name="resume_behavior" class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"><option value="tailor">Tailor for each job</option><option value="original">Use original resume</option></select></label><label class="text-sm font-bold">Salary minimum<input name="salary_min" value="" placeholder="Optional" class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"></label></div><div id="human-kickoff" class="mt-5 hidden rounded-2xl bg-human-50 p-5"><div class="grid gap-5 sm:grid-cols-[1fr_auto] sm:items-end"><label class="text-sm font-bold">Your WhatsApp number<input name="whatsapp_phone" type="tel" autocomplete="tel" placeholder="+234 801 234 5678" class="mt-2 w-full rounded-xl bg-white px-4 py-3 font-normal"/><span class="mt-2 block text-xs font-normal text-ink-soft">Include your country code. Operations uses this only to add you to your private Scout group.</span></label><a href="/book-call" class="shrink-0 rounded-full bg-ink px-5 py-3 text-center text-sm font-extrabold text-white">Schedule kickoff call</a></div></div></div></section>
      <div class="mx-auto mt-8 flex max-w-4xl items-center justify-between gap-3"><button id="back" type="button" class="invisible rounded-full px-5 py-3 font-bold text-ink-soft">Back</button><button id="next" type="button" class="rounded-full bg-ink px-7 py-3.5 font-extrabold text-white">Continue</button><button id="finish" type="submit" class="hidden rounded-full bg-brand-500 px-7 py-3.5 font-extrabold text-ink">Open my dashboard</button></div>
    </form>
  </div>
</section>
<script is:inline>
(function(){
  let step=1, extraction=null, extracting=false;
  const form=document.getElementById("onboarding-form"),panels=[...document.querySelectorAll(".step-panel")],next=document.getElementById("next"),back=document.getElementById("back"),finish=document.getElementById("finish"),progress=document.getElementById("progress"),label=document.getElementById("step-label"),file=document.getElementById("resume-file"),fileLabel=document.getElementById("file-label");
  const roles=document.querySelector("[name=target_roles]"),locations=document.querySelector("[name=locations]"),salary=document.querySelector("[name=salary_min]"),resumeId=document.querySelector("[name=resume_id]");
  function render(){panels.forEach((p,i)=>p.classList.toggle("hidden",i!==step-1));progress.style.width=(step*25)+"%";label.textContent="Step "+step+" of 4";back.classList.toggle("invisible",step===1);next.classList.toggle("hidden",step===4||extracting);finish.classList.toggle("hidden",step!==4);const human=document.querySelector("input[name=assistant]:checked")?.value==="human";document.getElementById("human-kickoff").classList.toggle("hidden",step!==4||!human);document.querySelector("[name=whatsapp_phone]").required=human}
  function showExtraction(data,failed){const d=data||{};document.getElementById("extraction-progress").style.width="100%";document.getElementById("extraction-kicker").textContent=failed?"Manual review needed":"Extraction complete";document.getElementById("extraction-message").textContent=failed?"We could not reliably analyze this file. Enter your job targets manually to continue.":"Review the extracted suggestions before your profile is created.";document.getElementById("extracted-headline").textContent=d.headline||d.contact?.name||"Resume uploaded";document.getElementById("extracted-summary").textContent=d.summary||"Your original resume is saved securely.";const chips=(d.skills||[]).slice(0,8);document.getElementById("extracted-skills").innerHTML=chips.map(x=>"<span class='rounded-full bg-white/10 px-3 py-2'></span>").join("");[...document.getElementById("extracted-skills").children].forEach((el,i)=>el.textContent=chips[i]);document.getElementById("extraction-checks").innerHTML="<div class='rounded-xl bg-signal-50 p-4'><strong>✓ Contact details</strong><p class='mt-1 text-sm text-ink-soft'>"+(d.contact?.location||"Review manually")+"</p></div><div class='rounded-xl bg-signal-50 p-4'><strong>✓ Professional history</strong><p class='mt-1 text-sm text-ink-soft'>"+(d.roles?.length||0)+" roles · "+(d.roles||[]).reduce((n,r)=>n+(r.achievements?.length||0),0)+" achievements</p></div><div class='rounded-xl bg-brand-100 p-4'><strong>"+chips.length+" skills found</strong><p class='mt-1 text-sm text-ink-soft'>All suggestions remain editable.</p></div>";if(!roles.value&&d.target_roles?.length)roles.value=d.target_roles.join(", ");if(!locations.value){const locs=d.preferred_locations?.length?d.preferred_locations:(d.contact?.location?[d.contact.location]:[]);locations.value=locs.join(", ")}if(!salary.value&&d.salary_min)salary.value=String(d.salary_min)}
  async function runExtraction(){extracting=true;step=3;render();try{const fd=new FormData();fd.append("resume",file.files[0]);const response=await fetch("/api/app/resume-extraction",{method:"POST",body:fd});const data=await response.json();if(!response.ok)throw new Error(data.error||"Resume upload failed");resumeId.value=data.resume.id;extraction=data.resume.extracted_data||{};showExtraction(extraction,data.resume.extraction_status==="failed");}catch(error){step=2;fileLabel.textContent=error.message||"Resume upload failed";alert(error.message||"Resume upload failed");}finally{extracting=false;render()}}
  next.addEventListener("click",async()=>{if(step===2&&!file.files[0]){fileLabel.textContent="Choose a resume to continue";return}if(step===2&&!resumeId.value){await runExtraction();return}if(step<4){step++;render()}});
  back.addEventListener("click",()=>{if(step>1){step--;render()}});
  file.addEventListener("change",()=>{resumeId.value="";extraction=null;if(file.files[0])fileLabel.textContent=file.files[0].name});
  form.addEventListener("submit",async(e)=>{e.preventDefault();finish.disabled=true;finish.textContent="Preparing your desk…";try{const response=await fetch(form.action,{method:"POST",body:new FormData(form)});const data=await response.json();if(!response.ok)throw new Error(data.error||"Setup failed");location.href=data.redirect||"/dashboard"}catch(error){finish.disabled=false;finish.textContent="Try again";alert(error.message)}});
  render();
})();
</script>
</Auth>
