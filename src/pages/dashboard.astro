---
import App from "../layouts/App.astro";
import AddJobDialog from "../components/AddJobDialog.astro";
import { applicationRows, loadScoutData } from "../lib/scout-data";
export const prerender = false;
const user = Astro.locals.user!;
const data = await loadScoutData(user, Astro.locals.supabase, Astro.locals.demoMode);
const rows = applicationRows(data);
const firstName = data.profile.full_name.split(" ")[0] || "there";
const today = new Intl.DateTimeFormat("en", { weekday:"long", month:"long", day:"numeric" }).format(new Date());
const weekAgo = Date.now() - 7*86400000;
const thisWeek = data.applications.filter(item => item.submitted_at && new Date(item.submitted_at).getTime() >= weekAgo).length;
const waiting = data.applications.filter(item => item.status === "preparing").length;
const assistant = data.profile.assistant_name || (data.profile.assistant_type === "human" ? "Your assistant" : "Scout AI");
---
<App title="Your Scout dashboard" active="dashboard">
  <div class="flex flex-wrap items-center justify-between gap-4"><div><p class="text-sm font-bold text-signal-700">{today}</p><h1 class="mt-1 text-3xl font-extrabold">Good to see you, {firstName}.</h1><p class="mt-2 text-ink-soft">Your application desk is moving. Everything your assistant does appears here.</p></div><AddJobDialog profiles={data.jobProfiles}/></div>
  <div class="mt-8 grid gap-4 sm:grid-cols-3"><div class="rounded-xl bg-brand-200 p-5"><p class="text-sm text-ink-soft">Applications this week</p><strong class="mt-2 block text-3xl">{thisWeek}</strong><span class="text-xs font-bold text-signal-700">{data.applications.length} tracked in total</span></div><div class="rounded-xl bg-white p-5 shadow-card"><p class="text-sm text-ink-soft">Being prepared</p><strong class="mt-2 block text-3xl">{waiting}</strong><span class="text-xs font-bold text-human-700">Open the queue for details</span></div><div class="rounded-xl bg-white p-5 shadow-card"><p class="text-sm text-ink-soft">Active job profiles</p><strong class="mt-2 block text-3xl">{data.jobProfiles.filter(item=>item.active).length}</strong><a href="/profiles" class="text-xs font-bold text-brand-700">Manage profiles →</a></div></div>
  <div class="mt-6 grid gap-6 xl:grid-cols-[1.35fr_0.65fr]">
    <section class="rounded-xl bg-white shadow-card"><div class="flex items-center justify-between border-b border-ink/10 p-5"><div><h2 class="text-xl font-extrabold">Recent applications</h2><p class="mt-1 text-sm text-ink-muted">Open any job to inspect the work.</p></div><a href="/applications" class="text-sm font-bold text-brand-700">View all</a></div><div class="divide-y divide-ink/10">{rows.length ? rows.slice(0,5).map(row=><a href={`/applications?id=${row.id}`} class="flex items-center justify-between gap-4 p-5 hover:bg-surface"><div><strong class="text-sm">{row.job!.title}</strong><p class="mt-1 text-xs text-ink-muted">{row.job!.company} · {row.jobProfile?.name || "General profile"}</p></div><div class="text-right"><span class={`rounded-full px-2.5 py-1 text-xs font-bold ${row.assistant_type==="human"?"bg-human-50 text-human-700":"bg-brand-100 text-brand-800"}`}>{row.assistant_type === "human" ? "Human" : "AI"}</span><p class="mt-2 text-xs font-bold text-signal-700">{row.status.replaceAll("_"," ")}</p></div></a>) : <div class="p-10 text-center"><strong>No applications yet</strong><p class="mt-2 text-sm text-ink-muted">Add a job and send it to your assistant.</p></div>}</div></section>
    <aside class="space-y-5"><div class="rounded-xl bg-brand-950 p-5 text-white"><div class="flex items-center gap-3"><span class="grid h-11 w-11 place-items-center rounded-full bg-human-500 font-extrabold">{assistant[0]}</span><div><strong class="text-white">{assistant}</strong><p class="text-xs text-white/55">Your {data.profile.assistant_type === "human" ? "Human" : "AI"} Assistant</p></div></div><p class="mt-5 text-sm leading-relaxed text-white/70">{data.profile.assistant_type === "human" ? "Your assistant will message you when an application needs a decision. Evidence appears with each submitted job." : "Scout AI is ready to prepare jobs using your selected profile and resume rules."}</p>{data.profile.assistant_type==="human" && <a href={data.profile.whatsapp_url || "https://wa.me/"} class="mt-5 block rounded-full bg-white px-4 py-3 text-center text-sm font-extrabold text-ink">Reply in WhatsApp</a>}</div><div class="rounded-xl bg-white p-5 shadow-card"><div class="flex justify-between"><strong>Scout for Chrome</strong><span class="text-signal-700">Ready</span></div><p class="mt-2 text-sm text-ink-soft">Send any job you find to a specific profile and assistant.</p><a href="/download" class="mt-4 block rounded-full bg-surface px-4 py-3 text-center text-sm font-extrabold">Add extension</a></div></aside>
  </div>
</App>
