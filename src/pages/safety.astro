---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import ProductScreenshot from "../components/ProductScreenshot.astro";
import FAQ from "../components/FAQ.astro";
import MarketingCTA from "../components/MarketingCTA.astro";
const faqs = [
 {q:"Can Scout submit without asking me each time?",a:"Yes, if you choose automatic approval for routine matches. You can also require approval for every role or only for specific companies, salary ranges, or assistant notes."},
 {q:"How does Scout avoid spammy application behavior?",a:"Scout uses preference guardrails, application pacing, per-role materials, and escalation when a form or question needs judgment."},
 {q:"Can I see what was submitted?",a:"Yes. The application log records the role, company, packet, submission time, assistant lane, and confirmation status."},
 {q:"What happens when AI is uncertain?",a:"The application can pause and return to you. Human Assistant is a separate service lane rather than an automatic escalation."},
];
---
<Base title="How Scout keeps job applications safe" description="Scout uses preference guardrails, tailored documents, safe pacing, approval modes, human escalation, and submission receipts.">
  <section class="bg-brand-950 py-20 text-white sm:py-28"><Container><div class="grid items-center gap-12 lg:grid-cols-2"><div><p class="text-lg font-bold text-brand-300">Control is a system, not a promise.</p><h1 class="mt-4 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] text-white sm:text-7xl">Applications move. Your boundaries stay fixed.</h1><p class="mt-6 max-w-xl text-lg leading-relaxed text-white/72">Scout keeps each job profile, resume choice, assistant lane, submission, and available piece of evidence visible.</p></div><ProductScreenshot variant="tracker" /></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">Five layers between a match and a submission.</h2></div><div class="mt-14 grid gap-4 lg:grid-cols-5"><article class="rounded-2xl bg-brand-200 p-6"><strong>Preference fit</strong><p class="mt-2 text-sm text-ink-soft">Roles, location, salary, and exclusions.</p></article><article class="rounded-2xl bg-surface p-6"><strong>Packet quality</strong><p class="mt-2 text-sm text-ink-soft">Materials prepared from the posting.</p></article><article class="rounded-2xl bg-brand-950 p-6 text-white"><strong>Approval mode</strong><p class="mt-2 text-sm text-white/70">Automatic, selective, or every application.</p></article><article class="rounded-2xl bg-human-50 p-6"><strong>Human evidence</strong><p class="mt-2 text-sm text-ink-soft">WhatsApp collaboration and answer screenshots.</p></article><article class="rounded-2xl bg-signal-50 p-6"><strong>Receipt</strong><p class="mt-2 text-sm text-ink-soft">Proof of what went out and when.</p></article></div></Container></section>
  <section class="bg-surface py-20 sm:py-28"><Container><div class="grid items-center gap-10 lg:grid-cols-2"><div><p class="text-lg font-bold text-human-700">Uncertainty has a destination</p><h2 class="mt-3 font-display text-4xl font-extrabold sm:text-6xl">Human members can ask the person doing the work.</h2><p class="mt-5 text-lg leading-relaxed text-ink-soft">Your dedicated assistant can confirm ambiguous salary, work authorization, and experience questions in WhatsApp before submitting.</p></div><ProductScreenshot variant="human" /></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl"><FAQ items={faqs} /></div></Container></section>
  <MarketingCTA title="Use automation with boundaries you can inspect." body="Choose the lane and approval rules you want, then inspect every job, resume, status, and lane-specific evidence record." />
</Base>
