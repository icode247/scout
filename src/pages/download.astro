---
import Base from "../layouts/Base.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import MarketingCTA from "../components/MarketingCTA.astro";
---
<Base title="Scout Chrome extension: send any job to your assistant" description="Add jobs from any job board to Scout, select the job profile and resume behavior, and send them to your Human or AI Assistant.">
  <section class="overflow-hidden bg-brand-950 py-20 text-white sm:py-28"><Container><div class="grid items-center gap-12 lg:grid-cols-[0.82fr_1.18fr]"><div><p class="text-lg font-bold text-brand-300">Scout for Chrome</p><h1 class="mt-4 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.035em] text-white sm:text-7xl">Found a job? Send it to your assistant from the page.</h1><p class="mt-6 max-w-xl text-lg leading-relaxed text-white/72">Invoke Scout on any job listing, choose the job profile and resume behavior, then add it to your Human or AI Assistant queue.</p><div class="mt-8 flex flex-col gap-3 sm:flex-row"><Button href="#" size="lg" class="rounded-full bg-brand-300 text-ink">Add Scout to Chrome</Button><Button href="/login" size="lg" variant="ghost" class="rounded-full bg-white/10 text-white">Sign in to Scout</Button></div><p class="mt-4 text-sm text-white/50">Chrome Web Store link placeholder — connect before launch</p></div><div class="rounded-2xl bg-white p-5 text-ink shadow-card"><div class="flex items-center justify-between border-b border-ink/10 pb-4"><div class="flex items-center gap-3"><span class="grid h-11 w-11 place-items-center rounded-lg bg-brand-300 text-xl font-black">S</span><div><strong>Send to Scout</strong><p class="text-xs text-ink-muted">Job detected on this page</p></div></div><span class="rounded-full bg-signal-50 px-3 py-1 text-xs font-bold text-signal-700">Ready</span></div><div class="mt-6 rounded-xl bg-surface p-4"><strong>Senior Product Manager</strong><p class="mt-1 text-sm text-ink-muted">Northstar Health · Remote</p></div><label class="mt-5 block text-sm font-bold">Job profile<select class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"><option>Product roles</option><option>Operations roles</option></select></label><label class="mt-4 block text-sm font-bold">Resume behavior<select class="mt-2 w-full rounded-xl bg-surface px-4 py-3 font-normal"><option>Tailor for this job</option><option>Use original resume</option></select></label><button class="mt-6 w-full rounded-full bg-ink px-5 py-3.5 font-extrabold text-white">Add to Human Assistant queue</button></div></div></Container></section>
  <section class="bg-white py-20 sm:py-28"><Container><div class="mx-auto max-w-3xl text-center"><h2 class="font-display text-4xl font-extrabold sm:text-6xl">The extension is a shortcut into the same operating system.</h2><p class="mt-5 text-lg text-ink-soft">Nothing becomes a separate browser-only list. The job appears in your dashboard with its selected profile, assistant lane, and resume rule.</p></div><div class="mt-12 grid gap-5 md:grid-cols-3"><div class="rounded-xl bg-brand-200 p-6"><strong>1. Detect the job</strong><p class="mt-2 text-sm text-ink-soft">Scout reads the title, company, location, and application URL.</p></div><div class="rounded-xl bg-surface p-6"><strong>2. Choose the profile</strong><p class="mt-2 text-sm text-ink-soft">Keep product, engineering, operations, and location-specific searches separate.</p></div><div class="rounded-xl bg-brand-950 p-6 text-white"><strong class="text-white">3. Delegate it</strong><p class="mt-2 text-sm text-white/70">Your selected assistant receives the job in the same queue you already track.</p></div></div></Container></section>
  <MarketingCTA title="Choose the assistant who will receive your next job." body="Human starts with a strategy call and WhatsApp group. AI starts with account creation and guided resume import." />
</Base>
